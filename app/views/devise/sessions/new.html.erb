<%= render layout: "devise/shared/auth_card",
           locals: {
             title: "Log in",
             subtitle: "Access your documents and continue reviewing legal files."
           } do %>
  <%= form_for(resource, as: resource_name, url: session_path(resource_name), html: { class: "mt-8 space-y-5" }) do |f| %>
    <%= render "devise/shared/field", form: f, field: :login, label: "Email or username", autocomplete: "username", autofocus: true %>
    <%= render "devise/shared/field", form: f, field: :password, label: "Password", type: :password, autocomplete: "current-password" %>

    <% if devise_mapping.rememberable? %>
      <label class="flex items-center gap-2 text-sm text-neutral-600">
        <%= f.check_box :remember_me, class: "h-4 w-4 rounded border-neutral-300 text-cyan-600 focus:ring-cyan-600" %>
        Remember me
      </label>
    <% end %>

    <%= f.submit "Log in", class: "btn btn-primary w-full" %>
  <% end %>

  <div class="mt-6 border-t border-neutral-200 pt-6 text-sm text-neutral-600">
    New here?
    <%= link_to "Create an account", new_registration_path(resource_name), class: "font-semibold text-cyan-700 hover:text-cyan-950" %>
  </div>
<% end %>
