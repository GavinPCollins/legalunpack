<div class="mx-auto w-full max-w-md">
  <%# CODEX auth color updates %>
  <div class="rounded-lg border border-neutral-200 bg-white p-8 shadow-sm">
    <h1 class="text-2xl font-semibold tracking-tight text-neutral-950">Log in</h1>
    <p class="mt-2 text-sm text-neutral-600">Access your documents and continue reviewing legal files.</p>

    <%= form_for(resource, as: resource_name, url: session_path(resource_name), html: { class: "mt-8 space-y-5" }) do |f| %>
      <div>
        <%= f.label :login, "Email or username", class: "block text-sm font-medium text-neutral-700" %>
        <%= f.text_field :login, autofocus: true, autocomplete: "username", class: "mt-2 block w-full rounded-md border border-neutral-300 px-3 py-2 text-neutral-950 outline-none focus:border-cyan-600 focus:ring-2 focus:ring-cyan-100" %>
      </div>

      <div>
        <%= f.label :password, class: "block text-sm font-medium text-neutral-700" %>
        <%= f.password_field :password, autocomplete: "current-password", class: "mt-2 block w-full rounded-md border border-neutral-300 px-3 py-2 text-neutral-950 outline-none focus:border-cyan-600 focus:ring-2 focus:ring-cyan-100" %>
      </div>

      <% if devise_mapping.rememberable? %>
        <label class="flex items-center gap-2 text-sm text-neutral-600">
          <%= f.check_box :remember_me, class: "h-4 w-4 rounded border-neutral-300 text-cyan-600 focus:ring-cyan-600" %>
          Remember me
        </label>
      <% end %>

      <%= f.submit "Log in", class: "w-full rounded-md bg-cyan-950 px-4 py-2.5 text-sm font-semibold text-neutral-50 hover:bg-cyan-900" %>
    <% end %>

    <div class="mt-6 border-t border-neutral-200 pt-6 text-sm text-neutral-600">
      New here?
      <%= link_to "Create an account", new_registration_path(resource_name), class: "font-semibold text-cyan-700 hover:text-cyan-950" %>
    </div>
  </div>
</div>
