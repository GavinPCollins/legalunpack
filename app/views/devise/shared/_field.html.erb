<div>
  <div class="flex items-center justify-between gap-3">
    <%= form.label field, label, class: "block text-sm font-medium text-neutral-700" %>
    <% if local_assigns[:hint].present? %>
      <span class="text-xs font-medium text-neutral-500"><%= hint %></span>
    <% end %>
  </div>
  <%= form.public_send(
        "#{local_assigns.fetch(:type, :text)}_field",
        field,
        {
          autocomplete: local_assigns[:autocomplete],
          autofocus: local_assigns[:autofocus],
          required: local_assigns[:required],
          class: "mt-2 block w-full rounded-md border border-neutral-300 px-3 py-2 text-neutral-950 outline-none focus:border-cyan-600 focus:ring-2 focus:ring-cyan-100"
        }.compact
      ) %>
</div>
