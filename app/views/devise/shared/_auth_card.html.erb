<div class="mx-auto w-full max-w-md">
  <div class="rounded-lg border border-neutral-200 bg-white p-8 shadow-sm">
    <h1 class="text-2xl font-semibold tracking-tight text-neutral-950"><%= title %></h1>
    <% if local_assigns[:subtitle].present? %>
      <p class="mt-2 text-sm text-neutral-600"><%= subtitle %></p>
    <% end %>

    <%= yield %>
  </div>
</div>
