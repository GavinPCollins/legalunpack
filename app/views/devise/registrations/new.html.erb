<%= render layout: "devise/shared/auth_card",
           locals: {
             title: "Create your account",
             subtitle: "Start a workspace for reviewing legal documents."
           } do %>
  <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { class: "mt-8 space-y-5" }) do |f| %>
    <%= render "devise/shared/error_messages", resource: resource %>

    <%= render "devise/shared/field", form: f, field: :name, label: "Name", autocomplete: "name" %>
    <%= render "devise/shared/field", form: f, field: :username, label: "Username", autocomplete: "username", autofocus: true, required: true %>
    <%= render "devise/shared/field", form: f, field: :email, label: "Email address", type: :email, autocomplete: "email", required: true %>
    <%= render "devise/shared/field",
               form: f,
               field: :password,
               label: "Password",
               type: :password,
               autocomplete: "new-password",
               required: true,
               hint: (@minimum_password_length ? "#{@minimum_password_length} characters minimum" : nil) %>
    <%= render "devise/shared/field",
               form: f,
               field: :password_confirmation,
               label: "Confirm password",
               type: :password,
               autocomplete: "new-password",
               required: true %>

    <%= f.submit "Create account", class: "btn btn-primary w-full" %>
  <% end %>

  <div class="mt-6 border-t border-neutral-200 pt-6 text-sm text-neutral-600">
    Already have an account?
    <%= link_to "Log in", new_session_path(resource_name), class: "font-semibold text-cyan-700 hover:text-cyan-950" %>
  </div>
<% end %>
