<div class="page-item" data-controller="modal">
  <%# ============================================================
      PAGE HEADER
      Package title, search, AI chat, and overflow actions.
      ============================================================ %>
  <%= render "components/headers/header_item",
        item_title: @package.name.presence || "Untitled package",
        item_subheader: "Created #{ @package.created_at.to_fs(:long)}",
        search_path: summary_search_doc_files_path,
        search_name: :q,
        search_params: { package_id: @package.id },
        search_placeholder: "Search AI summaries",
        search_drawer_title: "Summary search",
        search_drawer_body: "Press Return to search this package's AI summaries.",
        search_frame_id: "summary_search_results",
        overflow_actions: [
          { label: "Rename package", type: :button, data: { action: "modal#open", modal_dialog_param: "rename" } },
          { label: "Add documents", type: :button, data: { action: "modal#open", modal_dialog_param: "documents" } },
          {
            label: "Delete package",
            path: package_path(@package),
            method: :delete,
            danger: true,
            form: { data: { turbo_confirm: "Delete #{@package.name.presence || "this package"}?" } }
          }
        ] %>
  <%# ======================== END PAGE HEADER ======================== %>

  <%# ============================================================
      RENAME PACKAGE MODAL
      Opened from the page header overflow menu.
      ============================================================ %>
  <div class="fixed inset-0 z-50 hidden" role="dialog" aria-modal="true" aria-labelledby="rename-package-title" data-modal-target="dialog" data-modal-name="rename">
    <div class="fixed inset-0 bg-neutral-950/40" aria-hidden="true" data-action="click->modal#close" data-modal-dialog-param="rename"></div>

    <div class="fixed inset-0 z-10 w-screen overflow-y-auto">
      <div class="flex min-h-full items-end justify-center p-4 text-center sm:items-center sm:p-0">
        <div class="relative w-full max-w-md rounded-lg bg-white p-6 text-left shadow-xl">
          <div class="flex items-start justify-between gap-4">
            <div>
              <h2 id="rename-package-title" class="text-lg font-semibold text-neutral-950">Rename package</h2>
              <p class="mt-1 text-sm text-neutral-500">Update the package name shown throughout Legalunpack.</p>
            </div>

            <button type="button" class="rounded-md px-2 py-1 text-sm font-semibold text-neutral-500 hover:bg-neutral-100 hover:text-neutral-950" data-action="modal#close" data-modal-dialog-param="rename">
              Close
            </button>
          </div>

          <%= form_with model: @package, class: "mt-6 space-y-5" do |form| %>
            <div>
              <%= form.label :name, "Package name", class: "block text-sm font-medium text-neutral-700" %>
              <%= form.text_field :name,
                    autofocus: true,
                    class: "mt-2 block w-full rounded-md border border-neutral-300 bg-white px-3 py-2 text-neutral-950 outline-none focus:border-cyan-600 focus:ring-2 focus:ring-cyan-100" %>
              <% @package.errors.full_messages_for(:name).each do |message| %>
                <p class="mt-2 text-sm text-red-600"><%= message %></p>
              <% end %>
            </div>

            <div class="flex items-center justify-end gap-3">
              <button type="button" class="rounded-md px-3 py-2 text-sm font-semibold text-neutral-700 hover:bg-neutral-100" data-action="modal#close" data-modal-dialog-param="rename">
                Cancel
              </button>
              <%= form.submit "Save name", class: "rounded-md bg-cyan-950 px-4 py-2 text-sm font-semibold text-neutral-50 hover:bg-cyan-900" %>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  </div>
  <%# ==================== END RENAME PACKAGE MODAL =================== %>

  <%# ============================================================
      ADD DOCUMENTS MODAL
      Opened from the page header overflow menu.
      ============================================================ %>
  <div class="fixed inset-0 z-50 hidden" role="dialog" aria-modal="true" aria-labelledby="add-documents-title" data-modal-target="dialog" data-modal-name="documents">
    <div class="fixed inset-0 bg-neutral-950/40" aria-hidden="true" data-action="click->modal#close" data-modal-dialog-param="documents"></div>

    <div class="fixed inset-0 z-10 w-screen overflow-y-auto">
      <div class="flex min-h-full items-end justify-center p-4 text-center sm:items-center sm:p-0">
        <div class="relative w-full max-w-lg rounded-lg bg-white p-6 text-left shadow-xl">
          <div class="flex items-start justify-between gap-4">
            <div>
              <h2 id="add-documents-title" class="text-lg font-semibold text-neutral-950">Add documents</h2>
              <p class="mt-1 text-sm text-neutral-500">Upload legal files to this package.</p>
            </div>

            <button type="button" class="rounded-md px-2 py-1 text-sm font-semibold text-neutral-500 hover:bg-neutral-100 hover:text-neutral-950" data-action="modal#close" data-modal-dialog-param="documents">
              Close
            </button>
          </div>

          <%= form_with url: doc_files_path, multipart: true, data: { controller: "file-upload" }, class: "mt-6 space-y-4" do %>
            <%= hidden_field_tag :package_id, @package.id %>
            <div class="rounded-md border-2 border-dashed border-neutral-300 bg-neutral-50 p-6 text-center" data-file-upload-target="dropzone" data-action="dragover->file-upload#dragover drop->file-upload#drop">
              <p class="text-sm font-medium text-neutral-950">Drop files here</p>
              <p class="mt-1 text-xs text-neutral-500">PDF, DOCX, TXT, RTF</p>
              <%= label_tag :package_document_files, "Select files", class: "mt-4 inline-flex cursor-pointer rounded-md border border-neutral-300 bg-white px-3 py-2 text-sm font-semibold text-neutral-700 hover:bg-neutral-50" %>
              <%= file_field_tag "files[]",
                    id: "package_document_files",
                    multiple: true,
                    accept: ".pdf,.docx,.txt,.rtf,application/pdf,application/vnd.openxmlformats-officedocument.wordprocessingml.document,application/rtf,application/x-rtf,text/rtf,text/plain",
                    class: "sr-only",
                    data: { file_upload_target: "input", action: "change->file-upload#select" } %>
            </div>
            <ul class="space-y-2 text-left text-sm text-neutral-700" data-file-upload-target="list" aria-live="polite"></ul>
            <div class="flex justify-end">
              <%= submit_tag "Upload", class: "rounded-md bg-cyan-950 px-4 py-2 text-sm font-semibold text-neutral-50 hover:bg-cyan-900" %>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  </div>
  <%# ==================== END ADD DOCUMENTS MODAL ==================== %>

  <%# ============================================================
      NEED-ATTENTION DATA
      A file needs attention when processing failed or it contains
      at least one clause marked as high risk.
      ============================================================ %>
  <%
    attention_files = @package.doc_files.select do |doc_file|
      doc_file.extraction_status == "failed" ||
        doc_file.ai_status == "failed" ||
        doc_file.clauses.any? { |clause| clause.risk_level == "high" }
    end
  %>
  <%# ==================== END NEED-ATTENTION DATA ==================== %>

  <%# ============================================================
      RIGHT PANEL: FILES
      Captured here, then passed into the details layout below.
      This uses a compact row because the sticky panel is narrower
      than the main content column.
      ============================================================ %>
  <% files_panel = capture do %>
    <section class="side-content">
      <div class="flex items-start justify-between gap-3">
        <div>
          <h2 class="text-base font-semibold text-neutral-950">Files</h2>
          <p class="mt-1 text-sm text-neutral-500">
            <%= pluralize(@package.doc_files.count, "uploaded file") %>
          </p>
        </div>

        <button type="button"
                class="shrink-0 rounded-md border border-neutral-300 bg-white px-2.5 py-1.5 text-xs font-semibold text-neutral-700 hover:bg-neutral-50"
                data-action="modal#open"
                data-modal-dialog-param="documents">
          Add files
        </button>
      </div>

      <% if @package.doc_files.any? %>
        <ul role="list" class="mt-4 divide-y divide-neutral-200 border-y border-neutral-200">
          <% @package.doc_files.each do |doc_file| %>
            <% file_failed = doc_file.extraction_status == "failed" || doc_file.ai_status == "failed" %>
            <% file_complete = doc_file.ai_status == "complete" %>

            <li class="py-3">
              <div class="flex min-w-0 items-start gap-3">
                <span class="mt-0.5 flex size-8 shrink-0 items-center justify-center rounded-md bg-cyan-50 text-cyan-800">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true" class="size-4">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-5.1a2.25 2.25 0 0 0-.659-1.591l-3.9-3.9A2.25 2.25 0 0 0 13.35 3H6.75A2.25 2.25 0 0 0 4.5 5.25v13.5A2.25 2.25 0 0 0 6.75 21h10.5a2.25 2.25 0 0 0 2.25-2.25v-4.5Z" />
                    <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 3.375V7.5A1.5 1.5 0 0 0 15 9h4.125" />
                  </svg>
                </span>

                <div class="min-w-0 flex-1">
                  <%= link_to(
                        doc_file.file.attached? ? doc_file.file.filename.to_s : "Untitled file",
                        summary_doc_file_path(doc_file),
                        class: "block truncate text-sm font-semibold text-neutral-950 hover:text-cyan-800"
                      ) %>
                  <p class="mt-1 text-xs <%= file_failed ? "text-red-700" : "text-neutral-500" %>">
                    <%= file_failed ? "Needs attention" : (file_complete ? "Analysis complete" : "Processing") %>
                  </p>
                </div>
              </div>
            </li>
          <% end %>
        </ul>
      <% else %>
        <div class="mt-4 rounded-md border border-dashed border-neutral-300 px-4 py-8 text-center">
          <p class="text-sm font-medium text-neutral-950">No files uploaded</p>
          <p class="mt-1 text-xs text-neutral-500">Add a document to begin reviewing this package.</p>
        </div>
      <% end %>
    </section>
  <% end %>
  <%# ====================== END RIGHT PANEL: FILES =================== %>

  <%# ============================================================
      TWO-COLUMN DETAILS LAYOUT
      Main content is on the left; the captured files panel is
      sticky on the right at the xl breakpoint.
      ============================================================ %>
  <%= render layout: "layouts/details_page", locals: { panel: files_panel } do %>
    <%# ==========================================================
        LEFT SECTION: NEED ATTENTION
        Shows package errors, failed files, and files containing
        high-risk clauses.
        ========================================================== %>
    <section class="content gap-6">
      <div class="flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between">
        <div>
          <h2 class="text-lg font-semibold text-neutral-950">Need attention</h2>
          <p class="mt-1 text-sm text-neutral-500">
            Failed processing and high-risk clauses appear here.
          </p>
        </div>

        <div class="flex shrink-0 flex-wrap gap-2">
          <%= link_to "View analysis", analysis_package_path(@package), class: "rounded-md px-3 py-2 text-sm font-semibold text-cyan-800 hover:bg-cyan-50 hover:text-cyan-950" %>
          <%= button_to "Analyze package", analyze_package_path(@package), method: :post, class: "rounded-md border border-cyan-800 px-3 py-2 text-sm font-semibold text-cyan-800 hover:bg-cyan-50 hover:text-cyan-950" %>
        </div>
      </div>

      <% @package.errors[:base].each do |message| %>
        <div class="rounded-md border border-red-200 bg-red-50 p-4">
          <p class="text-sm font-medium text-red-800"><%= message %></p>
        </div>
      <% end %>

      <% if attention_files.any? %>
        <ul role="list" class="space-y-3">
          <% attention_files.each do |doc_file| %>
            <% high_risk_count = doc_file.clauses.count { |clause| clause.risk_level == "high" } %>
            <% processing_failed = doc_file.extraction_status == "failed" || doc_file.ai_status == "failed" %>

            <li class="rounded-md border <%= processing_failed ? "border-red-200 bg-red-50" : "border-amber-200 bg-amber-50" %> p-4">
              <div class="flex flex-col gap-3 sm:flex-row sm:items-start sm:justify-between">
                <div class="min-w-0">
                  <p class="truncate text-sm font-semibold text-neutral-950">
                    <%= doc_file.file.attached? ? doc_file.file.filename.to_s : "Untitled file" %>
                  </p>
                  <p class="mt-1 text-sm <%= processing_failed ? "text-red-700" : "text-amber-800" %>">
                    <% if processing_failed %>
                      Document processing failed and may need to be retried.
                    <% else %>
                      <%= pluralize(high_risk_count, "high-risk clause") %> found.
                    <% end %>
                  </p>
                </div>

                <%= link_to "Review file",
                      summary_doc_file_path(doc_file),
                      class: "shrink-0 text-sm font-semibold text-cyan-800 hover:text-cyan-950" %>
              </div>
            </li>
          <% end %>
        </ul>
      <% elsif @package.errors[:base].blank? %>
        <div class="rounded-md border border-dashed border-neutral-300 px-4 py-12 text-center">
          <p class="text-sm font-medium text-neutral-950">Nothing needs attention</p>
          <p class="mt-1 text-sm text-neutral-500">Failed processing and high-risk clauses will appear here.</p>
        </div>
      <% end %>
    </section>
    <%# ================== END LEFT SECTION: NEED ATTENTION ============ %>
  <% end %>
  <%# ================= END TWO-COLUMN DETAILS LAYOUT ================= %>
</div>
