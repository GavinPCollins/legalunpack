<% analysis_in_progress = @package.doc_files.any? { |doc_file| doc_file.ai_status == "processing" } %>
<%
  processing_files = @package.doc_files.select { |doc_file| doc_file.ai_status == "processing" }
  current_analysis_file =
    processing_files.find { |doc_file| doc_file.analysis_stage.present? && doc_file.analysis_stage != "waiting" } ||
    processing_files.min_by { |doc_file| [doc_file.analysis_position || Float::INFINITY, doc_file.id] }
  package_analysis_label = current_analysis_file&.analysis_batch_label || "Analyzing file"
%>

<div id="package-dashboard-<%= @package.id %>"
     class="page-item"
     data-controller="modal package-status-poll"
     data-package-status-poll-active-value="<%= analysis_in_progress %>"
     data-package-status-poll-url-value="<%= package_path(@package) %>">
  <%# ============================================================
      PAGE HEADER
      Package title, search, AI chat, and overflow actions.
      ============================================================ %>
  <%= render "components/headers/header_item",
        item_title: @package.name.presence || "Untitled package",
        item_subheader: "Created #{ @package.created_at.to_fs(:long)}",
        search_path: summary_search_doc_files_path,
        search_name: :q,
        search_params: { package_id: @package.id },
        search_placeholder: "Search this package",
        search_drawer_title: "Package search",
        search_drawer_body: "Press Return to search this package.",
        search_frame_id: "summary_search_results",
        ai_chat_url: package_chatbot_sessions_path(@package),
        overflow_actions: [
          { label: "Rename package", type: :button, data: { action: "modal#open", modal_dialog_param: "rename" } },
          { label: "Add documents", type: :button, data: { action: "modal#open", modal_dialog_param: "documents" } },
          {
            label: "Delete package",
            path: package_path(@package),
            method: :delete,
            danger: true,
            form: { data: { turbo_confirm: "Delete #{@package.name.presence || "this package"}?" } }
          }
        ] %>
  <%# ======================== END PAGE HEADER ======================== %>

  <%# ============================================================
      RENAME PACKAGE MODAL
      Opened from the page header overflow menu.
      ============================================================ %>
  <div class="fixed inset-0 z-50 hidden" role="dialog" aria-modal="true" aria-labelledby="rename-package-title" data-modal-target="dialog" data-modal-name="rename">
    <div class="fixed inset-0 bg-neutral-950/40" aria-hidden="true" data-action="click->modal#close" data-modal-dialog-param="rename"></div>

    <div class="fixed inset-0 z-10 w-screen overflow-y-auto">
      <div class="flex min-h-full items-end justify-center p-4 text-center sm:items-center sm:p-0">
        <div class="relative w-full max-w-md rounded-lg bg-white p-6 text-left shadow-xl">
          <div class="flex items-start justify-between gap-4">
            <div>
              <h2 id="rename-package-title" class="text-lg font-semibold text-neutral-950">Rename package</h2>
              <p class="mt-1 text-sm text-neutral-500">Update the package name shown throughout Legalunpack.</p>
            </div>

            <button type="button" class="btn" data-action="modal#close" data-modal-dialog-param="rename">
              Close
            </button>
          </div>

          <%= form_with model: @package, class: "mt-6 space-y-5" do |form| %>
            <div>
              <%= form.label :name, "Package name", class: "block text-sm font-medium text-neutral-700" %>
              <%= form.text_field :name,
                    autofocus: true,
                    class: "mt-2 block w-full rounded-md border border-neutral-300 bg-white px-3 py-2 text-neutral-950 outline-none focus:border-cyan-600 focus:ring-2 focus:ring-cyan-100" %>
              <% @package.errors.full_messages_for(:name).each do |message| %>
                <p class="mt-2 text-sm text-red-600"><%= message %></p>
              <% end %>
            </div>

            <div class="flex items-center justify-end gap-3">
              <button type="button" class="btn" data-action="modal#close" data-modal-dialog-param="rename">
                Cancel
              </button>
              <%= form.submit "Save name", class: "btn btn-primary" %>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  </div>
  <%# ==================== END RENAME PACKAGE MODAL =================== %>

  <%# ============================================================
      ADD DOCUMENTS MODAL
      Opened from the page header overflow menu.
      ============================================================ %>
  <div class="fixed inset-0 z-50 hidden" role="dialog" aria-modal="true" aria-labelledby="add-documents-title" data-modal-target="dialog" data-modal-name="documents">
    <div class="fixed inset-0 bg-neutral-950/40" aria-hidden="true" data-action="click->modal#close" data-modal-dialog-param="documents"></div>

    <div class="fixed inset-0 z-10 w-screen overflow-y-auto">
      <div class="flex min-h-full items-end justify-center p-4 text-center sm:items-center sm:p-0">
        <div class="relative w-full max-w-lg rounded-lg bg-white p-6 text-left shadow-xl">
          <div class="flex items-start justify-between gap-4">
            <div>
              <h2 id="add-documents-title" class="text-lg font-semibold text-neutral-950">Add documents</h2>
              <p class="mt-1 text-sm text-neutral-500">Upload legal files to this package.</p>
            </div>

            <button type="button" class="btn" data-action="modal#close" data-modal-dialog-param="documents">
              Close
            </button>
          </div>

          <%= form_with url: doc_files_path, multipart: true, data: { controller: "file-upload" }, class: "mt-6 space-y-4" do %>
            <%= hidden_field_tag :package_id, @package.id %>
            <div class="rounded-md border-2 border-dashed border-neutral-300 bg-neutral-50 p-6 text-center" data-file-upload-target="dropzone" data-action="dragover->file-upload#dragover drop->file-upload#drop">
              <p class="text-sm font-medium text-neutral-950">Drop files here</p>
              <p class="mt-1 text-xs text-neutral-500">PDF, DOCX, TXT, RTF</p>
              <%= label_tag :package_document_files, "Select files", class: "btn btn-secondary mt-4" %>
              <%= file_field_tag "files[]",
                    id: "package_document_files",
                    multiple: true,
                    accept: ".pdf,.docx,.txt,.rtf,application/pdf,application/vnd.openxmlformats-officedocument.wordprocessingml.document,application/rtf,application/x-rtf,text/rtf,text/plain",
                    class: "sr-only",
                    data: { file_upload_target: "input", action: "change->file-upload#select" } %>
            </div>
            <ul class="space-y-2 text-left text-sm text-neutral-700" data-file-upload-target="list" aria-live="polite"></ul>
            <div class="flex justify-end">
              <%= submit_tag "Upload", class: "btn btn-primary" %>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  </div>
  <%# ==================== END ADD DOCUMENTS MODAL ==================== %>

  <%# ============================================================
      NEED-ATTENTION DATA
      File issues appear first, followed by individual package flags.
      ============================================================ %>
  <%
    file_issue_files = @package.doc_files.select do |doc_file|
      doc_file.extraction_status == "failed" ||
        doc_file.ai_status == "failed"
    end

    analysis_required_files = @package.doc_files.select do |doc_file|
      doc_file.ai_status != "complete" &&
        doc_file.extraction_status != "failed" &&
        doc_file.ai_status != "failed"
    end

    active_package_flags = @package.clauses
                                   .flat_map(&:flags)
                                   .reject(&:resolved?)

    ordered_doc_files = @package.doc_files.sort_by { |doc_file| [doc_file.created_at, doc_file.id] }
  %>
  <%# ==================== END NEED-ATTENTION DATA ==================== %>

  <%# ============================================================
      RIGHT PANEL: FILES
      Captured here, then passed into the details layout below.
      This uses a compact row because the sticky panel is narrower
      than the main content column.
      ============================================================ %>
  <% files_panel = capture do %>
    <section class="side-content">

      <%# SECTION HEADER %>
      <div class="flex items-start justify-between gap-3">
        <div>
          <h2 class="text-base font-semibold text-neutral-950">Files</h2>
          <p class="mt-1 text-sm text-neutral-500">
            <%= pluralize(@package.doc_files.count, "file") %>
          </p>
        </div>
        <%# Header Actions %>
        <div class="flex shrink-0 items-center">
          <%= button_to analyze_package_path(@package),
                method: :post,
                class: "btn btn-icon" do %>
            <svg xmlns="http://www.w3.org/2000/svg"
                 fill="none"
                 viewBox="0 0 24 24"
                 stroke-width="1.5"
                 stroke="currentColor"
                 aria-hidden="true"
                 class="size-4">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904 9 18.75l-.813-2.846a4.5 4.5 0 0 0-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 0 0 3.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 0 0 3.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 0 0-3.09 3.09ZM18.259 8.715 18 9.75l-.259-1.035a3.375 3.375 0 0 0-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 0 0 2.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 0 0 2.456 2.456L21.75 6l-1.035.259a3.375 3.375 0 0 0-2.456 2.456ZM16.894 20.567 16.5 21.75l-.394-1.183a2.25 2.25 0 0 0-1.423-1.423L13.5 18.75l1.183-.394a2.25 2.25 0 0 0 1.423-1.423l.394-1.183.394 1.183a2.25 2.25 0 0 0 1.423 1.423l1.183.394-1.183.394a2.25 2.25 0 0 0-1.423 1.423Z" />
            </svg>
            <span>Run analysis</span>
          <% end %>
        </div>
      </div>

      <% if @package.doc_files.any? %>
        <ul role="list" class="mt-4 divide-y divide-neutral-200 border-y border-neutral-200">
          <% ordered_doc_files.each do |doc_file| %>
            <% file_failed = doc_file.extraction_status == "failed" || doc_file.ai_status == "failed" %>
            <% file_complete = doc_file.ai_status == "complete" %>
            <% file_processing = doc_file.ai_status == "processing" %>
            <% file_analysis_failed = doc_file.ai_status == "failed" %>
            <% file_name = doc_file.file.attached? ? doc_file.file.filename.to_s : "Untitled file" %>
            <% flag_count = doc_file.clauses.sum { |clause| clause.flags.size } %>

<%# New Version %>
  <li class="flex items-center justify-between gap-x-6 py-5">
    <div class="min-w-0 flex-1">
      <%# Upload date: top line. %>
      <div class="mt-1 flex items-center gap-x-2 text-xs/5 text-gray-500 dark:text-gray-400">
        <p class="whitespace-nowrap">
          Uploaded <time datetime="<%= doc_file.created_at.iso8601 %>"><%= doc_file.created_at.to_date.to_fs(:long) %></time>
        </p>
      </div>

      <%# Filename: middle line and link to the file summary page. %>
      <div class="flex items-start gap-x-3">
        <%= link_to(
                        file_name,
                        summary_doc_file_path(doc_file),
                        class: "block truncate text-sm/6 font-semibold text-neutral-800 hover:text-cyan-800"
                      ) %>
        <%# <p class="mt-0.5 rounded-md bg-green-50 px-1.5 py-0.5 text-xs font-medium text-green-700 inset-ring inset-ring-green-600/20 dark:bg-green-400/10 dark:text-green-400 dark:inset-ring-green-500/20">
          Complete
        </p> %>
      </div>

      <%# Analysis and risk status: bottom line. %>
      <div class="mt-1 flex flex-wrap items-center gap-x-2 text-xs/5 text-neutral-500">
        <% if file_processing %>
          <span class="flex items-center gap-1.5 text-cyan-800">
            <svg viewBox="0 0 24 24" fill="none" aria-hidden="true" class="size-3.5 animate-spin">
              <circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="2" class="opacity-25" />
              <path d="M21 12a9 9 0 0 0-9-9" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
            </svg>
            <span class="font-medium"><%= doc_file.analysis_progress_label %></span>
          </span>
        <% elsif file_analysis_failed %>
          <span class="flex items-center gap-1.5 font-medium text-red-700">
            <svg xmlns="http://www.w3.org/2000/svg"
                 fill="none"
                 viewBox="0 0 24 24"
                 stroke-width="1.5"
                 stroke="currentColor"
                 aria-hidden="true"
                 class="size-4">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126ZM12 15.75h.007v.008H12v-.008Z" />
            </svg>
            <span>Analysis failed</span>
          </span>
        <% else %>
          <span><%= file_complete ? "Analysed" : "Not analysed" %></span>
        <% end %>

        <% if file_complete && !file_processing %>
          <svg viewBox="0 0 2 2" class="size-0.5 shrink-0 fill-current" aria-hidden="true">
            <circle r="1" cx="1" cy="1" />
          </svg>

          <% if flag_count.positive? %>
            <%= link_to flags_doc_file_path(doc_file),
                  class: "flex shrink-0 items-center gap-1 rounded-md p-1 text-red-700 hover:bg-red-50 hover:text-red-900",
                  title: "#{pluralize(flag_count, "flag")} found",
                  aria: { label: "View #{pluralize(flag_count, "flag")} for #{file_name}" } do %>
              <svg xmlns="http://www.w3.org/2000/svg"
                   fill="none"
                   viewBox="0 0 24 24"
                   stroke-width="1.5"
                   stroke="currentColor"
                   aria-hidden="true"
                   class="size-4">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 3v1.5M3 21v-6m0 0 2.77-.693a9 9 0 0 1 6.208.682l.108.054a9 9 0 0 0 6.086.71l3.114-.732a48.524 48.524 0 0 1-.005-10.499l-3.11.732a9 9 0 0 1-6.085-.711l-.108-.054a9 9 0 0 0-6.208-.682L3 4.5M3 15V4.5" />
              </svg>
              <span class="text-xs font-semibold"><%= flag_count %></span>
            <% end %>
          <% else %>
            <span class="flex shrink-0 items-center gap-1 text-green-700">
              <svg xmlns="http://www.w3.org/2000/svg"
                   fill="none"
                   viewBox="0 0 24 24"
                   stroke-width="1.5"
                   stroke="currentColor"
                   aria-hidden="true"
                   class="size-4">
                <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
              </svg>
              <span class="font-medium">Looks good</span>
            </span>
          <% end %>
        <% end %>
      </div>
    </div>

    <%# Overflow action stays vertically centred at the right edge. %>
    <div class="ml-auto flex flex-none items-center justify-end">
      <details class="group relative" data-controller="menu">
        <summary class="relative block cursor-pointer list-none rounded-md p-1 text-neutral-500 hover:bg-neutral-100 hover:text-neutral-950 [&::-webkit-details-marker]:hidden">
          <span class="absolute -inset-2.5"></span>
          <span class="sr-only">Open options for <%= file_name %></span>
          <svg viewBox="0 0 20 20" fill="currentColor" data-slot="icon" aria-hidden="true" class="size-5">
            <path d="M10 3a1.5 1.5 0 1 1 0 3 1.5 1.5 0 0 1 0-3ZM10 8.5a1.5 1.5 0 1 1 0 3 1.5 1.5 0 0 1 0-3ZM11.5 15.5a1.5 1.5 0 1 0-3 0 1.5 1.5 0 0 0 3 0Z" />
          </svg>
        </summary>

        <div class="fixed z-50 w-36 rounded-md bg-white py-1 shadow-lg ring-1 ring-neutral-950/5"
             data-menu-target="panel">
          <%= link_to "Open",
                summary_doc_file_path(doc_file),
                class: "block px-3 py-2 text-sm text-neutral-700 hover:bg-neutral-50 hover:text-neutral-950" %>

          <% if doc_file.file.attached? %>
            <%= link_to "Download",
                  rails_blob_path(doc_file.file, disposition: "attachment"),
                  class: "block px-3 py-2 text-sm text-neutral-700 hover:bg-neutral-50 hover:text-neutral-950" %>
          <% end %>

          <%= button_to "Remove",
                doc_file_path(doc_file),
                method: :delete,
                class: "block w-full px-3 py-2 text-left text-sm text-red-700 hover:bg-red-50 hover:text-red-900",
                form_class: "contents",
                form: { data: { turbo_confirm: "Remove #{file_name} from this package?" } } %>
        </div>
      </details>
    </div>
  </li>
          <% end %>
        </ul>
      <% else %>
        <div class="mt-4 rounded-md border border-dashed border-neutral-300 px-4 py-8 text-center">
          <p class="text-sm font-medium text-neutral-950">No files uploaded</p>
          <p class="mt-1 text-xs text-neutral-500">Add a document to begin reviewing this package.</p>
        </div>
      <% end %>

      <%# Add-files action: centred below the file list or empty state. %>
      <div class="mt-5 flex justify-center">
        <button type="button"
                class="btn btn-icon btn-secondary"
                data-action="modal#open"
                data-modal-dialog-param="documents">
          <svg xmlns="http://www.w3.org/2000/svg"
               fill="none"
               viewBox="0 0 24 24"
               stroke-width="1.5"
               stroke="currentColor"
               aria-hidden="true"
               class="size-4">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
          </svg>
          <span>Add files</span>
        </button>
      </div>
    </section>
  <% end %>
  <%# ====================== END RIGHT PANEL: FILES =================== %>

  <%# ============================================================
      TWO-COLUMN DETAILS LAYOUT
      Main content is on the left; the captured files panel is
      sticky on the right at the xl breakpoint.
      ============================================================ %>
  <%= render layout: "layouts/details_page", locals: { panel: files_panel } do %>
    <%# ==========================================================
        LEFT SECTION: NEED ATTENTION
        Shows package errors, failed files, and files containing flags.
        ========================================================== %>
    <section class="content gap-6">
      <div class="flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between">
        <div>
          <h2 class="text-lg font-semibold text-neutral-950">Need attention</h2>
          <p class="mt-1 text-sm text-neutral-500">
            Failed processing and flags appear here.
          </p>
        </div>

        <%# <div class="flex shrink-0 flex-wrap gap-2"> %>
          <%#= link_to "View analysis", analysis_package_path(@package), class: "btn" %>
        <%# </div> %>
      </div>

      <% @package.errors[:base].each do |message| %>
        <div class="rounded-md border border-red-200 bg-red-50 p-4">
          <p class="text-sm font-medium text-red-800"><%= message %></p>
        </div>
      <% end %>

      <% if analysis_required_files.any? %>
        <div class="rounded-md border border-amber-200 bg-amber-50 shadow-sm">
          <div class="px-4 py-5 sm:p-6">
            <h3 class="text-base font-semibold text-neutral-950">Analysis required</h3>
            <div class="mt-2 sm:flex sm:items-start sm:justify-between">
              <div class="max-w-xl text-sm text-amber-800">
                <p>
                  <%= pluralize(analysis_required_files.count, "uploaded file") %>
                  <%= analysis_required_files.one? ? "requires" : "require" %> AI analysis.
                </p>
              </div>
              <div class="mt-5 sm:mt-0 sm:ml-6 sm:flex sm:shrink-0 sm:items-center"
                   data-package-status-poll-target="analysisAction">
                <% if analysis_in_progress %>
                  <div class="flex items-center gap-1.5 text-cyan-800">
                    <svg viewBox="0 0 24 24" fill="none" aria-hidden="true" class="size-3.5 animate-spin">
                      <circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="2" class="opacity-25" />
                      <path d="M21 12a9 9 0 0 0-9-9" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
                    </svg>
                    <span class="text-sm font-medium"><%= package_analysis_label %></span>
                  </div>
                <% else %>
                  <%= button_to analyze_package_path(@package),
                        method: :post,
                        class: "btn btn-icon",
                        form: { data: { action: "submit->package-status-poll#markAnalysisStarted" } } do %>
                    <svg xmlns="http://www.w3.org/2000/svg"
                         fill="none"
                         viewBox="0 0 24 24"
                         stroke-width="1.5"
                         stroke="currentColor"
                         aria-hidden="true"
                         class="size-4">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904 9 18.75l-.813-2.846a4.5 4.5 0 0 0-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 0 0 3.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 0 0 3.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 0 0-3.09 3.09ZM18.259 8.715 18 9.75l-.259-1.035a3.375 3.375 0 0 0-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 0 0 2.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 0 0 2.456 2.456L21.75 6l-1.035.259a3.375 3.375 0 0 0-2.456 2.456ZM16.894 20.567 16.5 21.75l-.394-1.183a2.25 2.25 0 0 0-1.423-1.423L13.5 18.75l1.183-.394a2.25 2.25 0 0 0 1.423-1.423l.394-1.183.394 1.183a2.25 2.25 0 0 0 1.423 1.423l1.183.394-1.183.394a2.25 2.25 0 0 0-1.423 1.423Z" />
                    </svg>
                    <span>Run analysis</span>
                  <% end %>
                <% end %>
              </div>
            </div>
          </div>
        </div>
      <% end %>

      <% if file_issue_files.any? %>
        <ul role="list" class="space-y-3">
          <% file_issue_files.each do |doc_file| %>
            <% processing_error_message = doc_file.processing_error_message.presence || "Document processing failed." %>
            <% file_name = doc_file.file.attached? ? doc_file.file.filename.to_s : "Untitled file" %>

            <li class="rounded-md border border-red-200 bg-red-50 p-4">
              <div class="flex flex-col gap-3 sm:flex-row sm:items-start sm:justify-between">
                <div class="min-w-0">
                  <p class="truncate text-sm font-semibold text-neutral-950">
                    Failed to analyse - <%= file_name %>
                  </p>
                  <p class="mt-1 text-sm text-neutral-950">
                    Reason: <%= processing_error_message %><br>
                    Upload different file or call customer support
                  </p>
                </div>

                <%= button_to "Delete file",
                      doc_file_path(doc_file),
                      method: :delete,
                      class: "shrink-0 text-sm font-semibold text-red-700 hover:text-red-900",
                      form_class: "contents",
                      form: { data: { turbo_confirm: "Delete #{file_name}?" } } %>
              </div>
            </li>
          <% end %>
        </ul>
      <% end %>

      <%= render "packages/active_flags", package: @package %>

      <% if @package.errors[:base].blank? && analysis_required_files.blank? && file_issue_files.blank? && active_package_flags.blank? %>
        <div class="rounded-md border border-dashed border-neutral-300 px-4 py-12 text-center">
          <p class="text-sm font-medium text-neutral-950">Nothing needs attention</p>
          <p class="mt-1 text-sm text-neutral-500">Failed processing and flags will appear here.</p>
        </div>
      <% end %>
    </section>
    <%# ================== END LEFT SECTION: NEED ATTENTION ============ %>

    <%# ==========================================================
        SMALL-SCREEN FILES SECTION
        The details layout hides its right panel below xl, so the
        same Files card is shown below Need attention instead.
        ========================================================== %>
    <div class="mt-8 xl:hidden">
      <%= files_panel %>
    </div>
