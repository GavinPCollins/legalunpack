<%# CODEX search function %>
<div class="mt-6 border-t border-neutral-200 pt-5">
  <div class="text-sm text-neutral-600">
    <h2 class="text-sm font-semibold text-neutral-950">Results</h2>
  </div>

  <% if packages.any? %>
    <ul class="mt-4 divide-y divide-neutral-200 rounded-md border border-neutral-200 bg-white">
      <% packages.each do |package| %>
        <li>
          <%= link_to package_path(package), class: "block px-4 py-4 transition hover:bg-cyan-50", data: { turbo_frame: "_top" } do %>
            <div class="flex items-start justify-between gap-4">
              <div class="min-w-0">
                <p class="truncate text-sm font-semibold text-neutral-950">
                  <%= highlighted_search_text(package.name.presence || "Untitled package", query) %>
                </p>
                <% filenames = package.doc_files.reject(&:archived?).filter_map { |doc_file| doc_file.file.filename.to_s if doc_file.file.attached? } %>
                <% if filenames.any? %>
                  <p class="mt-1 truncate text-sm text-neutral-500">
                    <%= safe_join(filenames.map { |filename| highlighted_search_text(filename, query) }, ", ") %>
                  </p>
                <% else %>
                  <p class="mt-1 text-sm text-neutral-500">No files uploaded</p>
                <% end %>
              </div>
              <span class="shrink-0 text-sm font-semibold text-cyan-800">Open package</span>
            </div>
          <% end %>
        </li>
      <% end %>
    </ul>
  <% else %>
    <div class="mt-4 rounded-md border border-dashed border-neutral-300 px-4 py-10 text-center">
      <p class="text-sm font-medium text-neutral-950">No matching packages</p>
      <p class="mt-1 text-sm text-neutral-500">Try a package name or uploaded file name.</p>
    </div>
  <% end %>
</div>
