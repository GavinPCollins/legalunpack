<%# CODEX search function %>
<div class="mt-6 border-t border-slate-200 pt-5">
  <div class="flex items-center justify-between gap-4 text-sm text-slate-600">
    <h2 class="text-sm font-semibold text-slate-950">Results</h2>
    <%= link_to "New package", new_package_path, class: "font-semibold text-sky-700 hover:text-sky-900", data: { turbo_frame: "_top" } %>
  </div>

  <% if packages.any? %>
    <ul class="mt-4 divide-y divide-slate-200 rounded-md border border-slate-200">
      <% packages.each do |package| %>
        <li>
          <%= link_to package_path(package), class: "block bg-white px-4 py-4 transition hover:bg-slate-50", data: { turbo_frame: "_top" } do %>
            <div class="flex items-start justify-between gap-4">
              <div class="min-w-0">
                <p class="truncate text-sm font-semibold text-slate-950"><%= package.name.presence || "Untitled package" %></p>
                <% filenames = package.doc_files.filter_map { |doc_file| doc_file.file.filename.to_s if doc_file.file.attached? } %>
                <% if filenames.any? %>
                  <p class="mt-1 truncate text-sm text-slate-500"><%= filenames.join(", ") %></p>
                <% else %>
                  <p class="mt-1 text-sm text-slate-500">No files uploaded</p>
                <% end %>
              </div>
              <span class="shrink-0 text-sm font-medium text-sky-700">Open</span>
            </div>
          <% end %>
        </li>
      <% end %>
    </ul>
  <% else %>
    <div class="mt-4 rounded-md border border-dashed border-slate-300 px-4 py-10 text-center">
      <p class="text-sm font-medium text-slate-900">No matching packages</p>
      <p class="mt-1 text-sm text-slate-500">Try a package name or an uploaded file name.</p>
    </div>
  <% end %>
</div>
