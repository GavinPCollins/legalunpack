<div class="page-main">
  <%= form_with model: @package, html: { multipart: true }, class: "upload-form", data: { controller: "file-upload" } do |form| %>
    <%= render "components/headers/header_main",
        page_header: "New Package",
        # page_subheader: "Find packages by package name or uploaded file name.",
        borderless_label: "Reset",
        borderless_path: root_path,
        primary_label: "Create",
        primary_type: :submit %>

    <section class="content">
      <div class="form">
        <div class="form-part">
          <%# <h2>Package details</h2>  %>
          <div class="field">
            <%= form.label :name, "Package name" %>
            <%= form.text_field :name, class: "input-text", placeholder: "Example: Lease review, Court notice, Employment contract" %>
          </div>
        </div>

        <%# Finished version %>
        <div class="form-part">
          <div class="field">
            <label>Upload files</label>

            <div class="file-dropzone" data-file-upload-target="dropzone" data-action="dragover->file-upload#dragover drop->file-upload#drop">
              <div class="file-dropzone-content">
                <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" class="file-upload-icon">
                  <path d="M1.5 6a2.25 2.25 0 0 1 2.25-2.25h16.5A2.25 2.25 0 0 1 22.5 6v12a2.25 2.25 0 0 1-2.25 2.25H3.75A2.25 2.25 0 0 1 1.5 18V6ZM3 16.06V18c0 .414.336.75.75.75h16.5A.75.75 0 0 0 21 18v-1.94l-2.69-2.689a1.5 1.5 0 0 0-2.12 0l-.88.879.97.97a.75.75 0 1 1-1.06 1.06l-5.16-5.159a1.5 1.5 0 0 0-2.12 0L3 16.061Zm10.125-7.81a1.125 1.125 0 1 1 2.25 0 1.125 1.125 0 0 1-2.25 0Z" clip-rule="evenodd" fill-rule="evenodd" />
                </svg>

                <div class="file-upload-row">
                  <%= label_tag :package_files, "Select files", class: "special-label" %>
                  <p>or drag and drop</p>
                </div>

                <p class="upload-help">Accepted file types: PDF, DOCX, TXT, RTF.</p>

                <%= file_field_tag "files[]",
                      id: "package_files",
                      multiple: true,
                      class: "sr-only",
                      accept: ".pdf,.docx,.txt,.rtf,application/pdf,application/vnd.openxmlformats-officedocument.wordprocessingml.document,application/rtf,application/x-rtf,text/rtf,text/plain",
                      data: { file_upload_target: "input", action: "change->file-upload#select" } %>
              </div>
            </div>
            <ul class="selected-files" data-file-upload-target="list" aria-live="polite"></ul>
          </div>
        </div>

        <% form_errors = @package.errors[:name] + @package.errors[:base] %>
        <% if form_errors.present? %>
          <div class="form-part">
            <% form_errors.each do |message| %>
              <p class="form-error"><%= message %></p>
            <% end %>
          </div>
        <% end %>
      </div>
    </section>
  <% end %>
</div>
