<%# CODEX search function updates %>
<% package_search_results = @query.present? ? render("doc_files/summary_search_results", doc_files: @doc_files, query: @query, frame_id: "package_search_results") : nil %>

<div class="page-item">
  <%= render "components/header_item",
        item_title: "Search Packages",
        item_subheader: "Search AI summaries across all packages.",
        search_path: packages_path,
        search_name: :q,
        search_value: @query,
        search_placeholder: "Search all AI summaries",
        search_drawer_title: "Package search",
        search_drawer_body: "Press Return to search AI summaries across all packages.",
        search_frame_id: "package_search_results",
        search_frame_content: package_search_results,
        show_ai_chat: false %>
</div>
