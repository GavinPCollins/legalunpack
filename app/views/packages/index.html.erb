<%# CODEX search function updates %>
<div class="page-main">
  <%= render "components/headers/header_main",
        page_header: "Search Packages",
        page_subheader: "Find packages by package name or uploaded file name." %>

  <section class="content">
    <div>
      <%= form_with url: packages_path,
            method: :get,
            data: { turbo_frame: "package_search_results" },
            class: "mt-6" do |form| %>
        <label for="package_search" class="sr-only">Search packages</label>
        <div class="relative">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true" class="pointer-events-none absolute left-3 top-1/2 size-5 -translate-y-1/2 text-neutral-400">
            <path stroke-linecap="round" stroke-linejoin="round" d="m21 21-4.35-4.35m1.35-5.4a6.75 6.75 0 1 1-13.5 0 6.75 6.75 0 0 1 13.5 0Z" />
          </svg>
          <%= form.search_field :q,
                id: "package_search",
                value: @query,
                placeholder: "Search package or file names",
                autocomplete: "off",
                class: "block w-full rounded-md border border-neutral-300 bg-white py-3 pl-10 pr-3 text-base text-neutral-950 outline-none transition focus:border-cyan-600 focus:ring-2 focus:ring-cyan-100" %>
        </div>
      <% end %>

      <%= turbo_frame_tag "package_search_results" do %>
        <%= render "packages/search_results", packages: @packages, query: @query if @query.present? %>
      <% end %>
    </div>
  </section>
</div>
