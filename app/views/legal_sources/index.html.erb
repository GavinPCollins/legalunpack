<div class="page-item">
  <%= render "components/headers/header_main",
        page_header: "Source Management",
        page_subheader: "Manage the trusted legal resources available to Legalunpack.",
        primary_label: "Add resource",
        primary_path: new_legal_source_path %>

  <section class="content">
    <% if @legal_sources.any? %>
      <div class="grid grid-cols-1 gap-4 md:grid-cols-2 xl:grid-cols-3">
        <% @legal_sources.each do |source| %>
          <article class="flex min-h-56 flex-col rounded-md border border-neutral-200 bg-white p-5 shadow-sm">
            <div class="flex items-start justify-between gap-3">
              <div class="min-w-0">
                <p class="text-xs font-semibold uppercase tracking-wide text-cyan-700"><%= source.jurisdiction %></p>
                <h2 class="mt-1 text-base font-semibold text-neutral-950"><%= source.title %></h2>
              </div>

              <span class="<%= class_names(
                "shrink-0 rounded-full px-2 py-1 text-xs font-semibold",
                source.imported? ? "bg-green-50 text-green-700" : "bg-amber-50 text-amber-800"
              ) %>">
                <%= source.imported? ? "Imported" : "Pending" %>
              </span>
            </div>

            <% if source.citation.present? %>
              <p class="mt-3 text-sm text-neutral-600"><%= source.citation %></p>
            <% end %>

            <dl class="mt-4 grid grid-cols-2 gap-3 text-sm">
              <div>
                <dt class="text-xs font-semibold uppercase tracking-wide text-neutral-500">Type</dt>
                <dd class="mt-1 text-neutral-900"><%= source.source_type.humanize %></dd>
              </div>
              <div>
                <dt class="text-xs font-semibold uppercase tracking-wide text-neutral-500">Authority</dt>
                <dd class="mt-1 text-neutral-900"><%= source.authority_level.humanize %></dd>
              </div>
              <div>
                <dt class="text-xs font-semibold uppercase tracking-wide text-neutral-500">Format</dt>
                <dd class="mt-1 text-neutral-900"><%= source.source_format.upcase %></dd>
              </div>
              <div>
                <dt class="text-xs font-semibold uppercase tracking-wide text-neutral-500">Publisher</dt>
                <dd class="mt-1 truncate text-neutral-900"><%= source.publisher.presence || "Not set" %></dd>
              </div>
            </dl>

            <% if source.source_name.present? %>
              <p class="mt-auto pt-4 text-xs text-neutral-500">
                <span class="font-semibold text-neutral-600">Source:</span>
                <span class="break-words"><%= source.source_name %></span>
              </p>
            <% end %>
          </article>
        <% end %>
      </div>
    <% else %>
      <div class="rounded-md border border-dashed border-neutral-300 bg-neutral-50 p-8 text-center">
        <h2 class="text-base font-semibold text-neutral-950">No resources yet</h2>
        <p class="mt-2 text-sm text-neutral-600">Add the first trusted legal source for retrieval.</p>
      </div>
    <% end %>
  </section>
</div>
