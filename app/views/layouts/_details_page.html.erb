<div class="mx-auto flex w-full max-w-7xl items-start gap-8 pb-8 pt-5">
  <section class="min-w-0 flex-1">
    <%= yield %>
  </section>

  <% if local_assigns[:panel].present? %>
    <aside class="sticky top-8 hidden max-h-[calc(100vh-4rem)] w-80 shrink-0 overflow-y-auto xl:block">
      <%= panel %>
    </aside>
  <% end %>
</div>
