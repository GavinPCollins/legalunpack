<!DOCTYPE html>
<html  class="h-full bg-neutral-50">
  <head>
    <title><%= content_for(:title) || "Legalunpack" %></title>
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Legalunpack">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

<%# >> Style A (Old) - stright top to bottom line border << %>
  <body class="min-h-screen h-full bg-neutral-50 text-neutral-950">

<%#  >> Style B (New) - rounded center, no right border to nav << %>
  <%# <body class="min-h-screen h-full bg-neutral-100 text-neutral-950"> %>

    <%# -- User Pages -- %>
    <% if user_signed_in? %>
      <div data-controller="sidebar" data-action="keydown@window->sidebar#closeOnEscape">
        <%# Mobile drawer: hidden by default, opened by the top-bar menu button. %>
        <div class="mobile-sidebar-shell hidden" data-sidebar-target="drawer">
          <button type="button" class="mobile-sidebar-backdrop" aria-label="Close sidebar" data-sidebar-target="backdrop" data-action="sidebar#close"></button>
          <div class="fixed inset-0 flex">
            <aside class="mobile-sidebar-panel" data-sidebar-target="panel">
              <div class="absolute left-full top-0 flex w-16 justify-center pt-5">
                <button type="button" class="-m-2.5 p-2.5 text-white" aria-label="Close sidebar" data-action="sidebar#close">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true" class="size-6">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" />
                  </svg>
                </button>
              </div>
              <%= render "components/side_nav" %>
            </aside>
          </div>
        </div>

        <%# Desktop sidebar: fixed in place from the large breakpoint upward. %>
        <aside class="side-nav-desktop">
          <%= render "components/side_nav" %>
        </aside>

        <%# Mobile top bar: gives small screens a clear drawer trigger. %>
        <header class="mobile-top-bar">
          <button type="button" class="-m-2.5 p-2.5 text-neutral-700 hover:text-neutral-950" aria-label="Open sidebar" data-action="sidebar#open">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true" class="size-6">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
            </svg>
          </button>
          <%= link_to root_path, aria: { label: "Legalunpack" }, class: "min-w-0 flex-1" do %>
            <%= image_tag "Logo9.svg", alt: "Legalunpack", class: "h-9 w-auto max-w-full object-contain" %>
          <% end %>
          <%= link_to edit_user_registration_path, aria: { label: "Profile" }, class: "flex size-9 shrink-0 items-center justify-center rounded-full bg-neutral-100 text-sm font-bold text-neutral-700 outline -outline-offset-1 outline-black/5" do %>
            <%= (current_user.try(:name).presence || current_user.username.presence || current_user.email).first.upcase %>
          <% end %>
        </header>

        <main class="app-main">
          <%= yield %>
        </main>
      </div>

    <%# -- no user --  %>
    <% else %>
      <header class="border-b border-neutral-200 bg-white">
        <nav class="mx-auto flex max-w-6xl items-center justify-between px-5 py-4">
          <%= link_to "Legalunpack", root_path, class: "text-lg font-semibold tracking-tight text-neutral-950" %>
          <div class="flex items-center gap-3 text-sm font-medium">
            <%= link_to "Log in", new_user_session_path, class: "rounded-md px-3 py-2 text-neutral-700 hover:bg-neutral-100" %>
            <%= link_to "Sign up", new_user_registration_path, class: "rounded-md bg-cyan-950 px-3 py-2 text-neutral-50 hover:bg-cyan-900" %>
          </div>
        </nav>
      </header>
      <main class="mx-auto flex w-full max-w-6xl px-5 py-12 mt-8 border-neutral-200">
        <%= yield %>
      </main>
    <% end %>


  </body>
</html>
