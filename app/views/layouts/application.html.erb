<!DOCTYPE html>
<html  class="h-full bg-white">
  <head>
    <title><%= content_for(:title) || "Legalunpack" %></title>
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Legalunpack">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="min-h-screen h-full bg-slate-50 text-slate-950">
    <header class="border-b border-slate-200 bg-white">
      <nav class="mx-auto flex max-w-6xl items-center justify-between px-5 py-4">
        <%= link_to "Legalunpack", root_path, class: "text-lg font-semibold tracking-tight text-slate-950" %>

        <div class="flex items-center gap-3 text-sm font-medium">
          <% if user_signed_in? %>
            <span class="text-slate-600"><%= current_user.try(:name).presence || current_user.username.presence || current_user.email %></span>
            <%= button_to "Log out", destroy_user_session_path, method: :delete, class: "rounded-md border border-slate-300 px-3 py-2 text-slate-700 hover:bg-slate-100" %>
          <% else %>
            <%= link_to "Log in", new_user_session_path, class: "rounded-md px-3 py-2 text-slate-700 hover:bg-slate-100" %>
            <%= link_to "Sign up", new_user_registration_path, class: "rounded-md bg-slate-950 px-3 py-2 text-white hover:bg-slate-800" %>
          <% end %>
        </div>
      </nav>
    </header>

    <main class="mx-auto flex w-full max-w-6xl px-5 py-12">
      <%= yield %>
    </main>
  </body>
</html>
