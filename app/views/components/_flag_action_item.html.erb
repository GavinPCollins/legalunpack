<% short_summary = flag.reason.presence || flag.clause.summary.presence %>
<% priority_label = flag.level.present? ? "#{flag.level.humanize} priority" : "Review" %>
<%
  priority_class =
    case flag.level
    when "high"
      "badge-danger"
    when "medium"
      "badge-warning"
    when "low"
      "badge-info"
    else
      "badge-neutral"
    end
%>

<article class="flex items-center justify-between gap-4 rounded-md border border-neutral-200 bg-white px-4 py-3">
  <div class="min-w-0">
    <div class="flex flex-wrap items-center gap-2">
      <h3 class="break-words text-sm font-semibold text-neutral-950"><%= flag.name %></h3>
      <span class="pill <%= priority_class %>"><%= priority_label %></span>
    </div>
    <% if short_summary.present? %>
      <p class="mt-1 text-sm leading-5 text-neutral-600"><%= short_summary %></p>
    <% end %>
  </div>

  <button type="button"
          class="btn shrink-0"
          data-action="flag-drawer#open">
    See more
  </button>
</article>
