<% resolved_flags = Array(flags).select(&:resolved?) %>
<% file_name = doc_file.file.attached? ? doc_file.file.filename.to_s : "Untitled file" %>

<% indicator_content = capture do %>
    <svg xmlns="http://www.w3.org/2000/svg"
         fill="none"
         viewBox="0 0 24 24"
         stroke-width="1.5"
         stroke="currentColor"
         aria-hidden="true"
         class="size-4">
      <path stroke-linecap="round" stroke-linejoin="round" d="M3 3v1.5M3 21v-6m0 0 2.77-.693a9 9 0 0 1 6.208.682l.108.054a9 9 0 0 0 6.086.71l3.114-.732a48.524 48.524 0 0 1-.005-10.499l-3.11.732a9 9 0 0 1-6.085-.711l-.108-.054a9 9 0 0 0-6.208-.682L3 4.5M3 15V4.5" />
    </svg>
    <span class="text-xs font-semibold"><%= resolved_flags.size %></span>
    <span class="text-xs italic">(Dismissed)</span>
<% end %>

<% if resolved_flags.many? %>
  <%= link_to dismissed_flags_doc_file_path(doc_file),
        class: "flex shrink-0 items-center gap-1 rounded-md p-1 text-neutral-600 hover:bg-neutral-100 hover:text-neutral-900",
        title: pluralize(resolved_flags.size, "dismissed flag"),
        aria: { label: "View #{pluralize(resolved_flags.size, "dismissed flag")} for #{file_name}" } do %>
    <%= indicator_content %>
  <% end %>
<% else %>
  <div class="inline-flex" data-controller="flag-drawer">
    <button type="button"
            class="flex shrink-0 items-center gap-1 rounded-md p-1 text-neutral-600 hover:bg-neutral-100 hover:text-neutral-900"
            title="<%= pluralize(resolved_flags.size, "dismissed flag") %>"
            aria-label="View <%= pluralize(resolved_flags.size, "dismissed flag") %> for <%= file_name %>"
            data-action="flag-drawer#open">
      <%= indicator_content %>
    </button>

    <%= render layout: "components/drawer",
          locals: {
            controller: "flag-drawer",
            title: "Dismissed flag",
            title_id: dom_id(doc_file, :resolved_flags_drawer_title),
            subtitle: file_name,
            dialog_class: "fixed inset-0 h-auto max-h-none w-auto max-w-none overflow-hidden bg-transparent backdrop:bg-transparent",
            shell_class: "absolute inset-0 pl-10 focus:outline-none sm:pl-16",
            panel_class: "ml-auto block h-full w-full max-w-2xl",
            content_class: "relative flex h-full flex-col overflow-hidden bg-white px-4 py-6 shadow-xl sm:px-6",
            header_class: "flex shrink-0 items-start justify-between gap-4",
            title_class: "text-base font-semibold text-neutral-950",
            subtitle_class: "mt-1 text-sm text-neutral-500",
            close_wrap_class: "",
            close_button_class: "relative rounded-md text-neutral-400 hover:text-neutral-600",
            body_class: "mt-6 flex-1 overflow-y-auto pb-6"
          } do %>
      <%= render "components/flag_group_item", flag: resolved_flags.first, render_context: "group_item" %>
    <% end %>
  </div>
  <% end %>
