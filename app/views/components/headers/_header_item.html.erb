<%# ---- Package ---- %>
<% item_title = local_assigns[:item_title] || local_assigns[:package_name] %>
<% item_subheader = local_assigns[:item_subheader] || local_assigns[:item_subtitle] %>

<%# ---- Badge ---- %>
<% badge_label = local_assigns[:badge_label] %>
<% badge_class = local_assigns[:badge_class] %>

<%# ---- Parent ---- %>
<% parent_label = local_assigns[:parent_label] %>
<% parent_path = local_assigns[:parent_path] %>

<%# ---- Search ---- %>
<% search_path = local_assigns[:search_path] || "#" %>
<% search_method = local_assigns[:search_method] || :get %>
<% search_name = local_assigns[:search_name] || :search %>
<% search_value = local_assigns[:search_value] %>
<% search_placeholder = local_assigns[:search_placeholder] || "Search" %>
<% search_label = local_assigns[:search_label] || search_placeholder %>
<% search_params = local_assigns[:search_params] || {} %>
<% search_frame_id = local_assigns[:search_frame_id] %>
<% search_frame_content = local_assigns[:search_frame_content] %>
<% search_drawer_title = local_assigns[:search_drawer_title] || "Search" %>
<% search_drawer_body = local_assigns[:search_drawer_body] || "Search results will appear here." %>
<% show_search_drawer = local_assigns.fetch(:show_search_drawer, true) %>

<%# ---- AI chat ---- %>
<% ai_chat_label = local_assigns[:ai_chat_label] || "Open AI chat" %>
<% ai_chat_path = local_assigns[:ai_chat_path] %>
<% ai_chat_drawer_title = local_assigns[:ai_chat_drawer_title] || "AI chat" %>
<% ai_chat_drawer_body = local_assigns[:ai_chat_drawer_body] || "Ask a question about this package. Chat responses will appear here once the chat action is connected." %>
<% show_ai_chat = local_assigns.fetch(:show_ai_chat, true) %>

<%# ---- Overflow actions ---- %>
<% overflow_label = local_assigns[:overflow_label] || "Open options" %>
<% overflow_actions = local_assigns[:overflow_actions] || [] %>

<% header_controllers = [] %>
<% header_controllers << "search-drawer" if show_search_drawer %>
<% header_controllers << "ai-chat-drawer" if show_ai_chat && ai_chat_path.blank? %>

<header class="item-header"<%= " data-controller=\"#{header_controllers.join(" ")}\"".html_safe if header_controllers.any? %>>
  <div class="item-header-frame">
    <% if parent_label.present? && parent_path.present? %>
      <div class="item-header-parent">
        <%= link_to parent_path, class: "item-header-parent-link" do %>
          <svg viewBox="0 0 20 20" fill="currentColor" aria-hidden="true" class="size-4">
            <path fill-rule="evenodd" d="M11.78 5.22a.75.75 0 0 1 0 1.06L8.06 10l3.72 3.72a.75.75 0 1 1-1.06 1.06l-4.25-4.25a.75.75 0 0 1 0-1.06l4.25-4.25a.75.75 0 0 1 1.06 0Z" clip-rule="evenodd" />
          </svg>
          <span><%= parent_label %></span>
        <% end %>
      </div>
    <% end %>

    <div class="item-header-inner">
    <%# ---- Package details ---- %>
    <div class="item-header-title">
      <% if item_title.present? %>
        <div class="item-header-title-row">
          <h1><%= item_title %></h1>
          <% if badge_label.present? %>
            <span class="<%= class_names("badge", badge_class) %>">
              <%= badge_label %>
            </span>
          <% end %>
        </div>

        <% if item_subheader.present? %>
          <p class="subheader"><%= item_subheader %></p>
        <% end %>
      <% end %>
    </div>

    <%# ---- Search form ---- %>
    <%= form_with url: search_path,
          method: search_method,
          class: "item-search",
          data: (show_search_drawer ? { action: "submit->search-drawer#open", turbo_frame: search_frame_id }.compact : {}) do %>
      <% search_params.each do |name, value| %>
        <%= hidden_field_tag name, value %>
      <% end %>

      <%= search_field_tag search_name,
            search_value,
            placeholder: search_placeholder,
            aria: { label: search_label },
            class: "search-field",
            data: (show_search_drawer ? { search_drawer_target: "query" } : {}) %>
      <svg viewBox="0 0 20 20" fill="currentColor" data-slot="icon" aria-hidden="true" class="mx-2 pointer-events-none col-start-1 row-start-1 size-5 self-center text-gray-400">
        <path d="M9 3.5a5.5 5.5 0 1 0 0 11 5.5 5.5 0 0 0 0-11ZM2 9a7 7 0 1 1 12.452 4.391l3.328 3.329a.75.75 0 1 1-1.06 1.06l-3.329-3.328A7 7 0 0 1 2 9Z" clip-rule="evenodd" fill-rule="evenodd" />
      </svg>
    <% end %>

    <div class="item-header-actions">

      <%# ---- Desktop separator ---- %>
      <%# <div aria-hidden="true" class="item-header-desktop-separator"></div> %>

     <div class="bar-right-section">

      <%# ---- AI chat button ---- %>
      <% if show_ai_chat %>
        <% if ai_chat_path.present? %>
          <%= link_to ai_chat_path, class: "item-header-icon-button" do %>
            <span class="sr-only"><%= ai_chat_label %></span>
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true" class="size-6">
              <path stroke-linecap="round" stroke-linejoin="round" d="M8.625 9.75a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Zm0 0H8.25m4.125 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Zm0 0H12m4.125 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Zm0 0h-.375m-13.5 3.01c0 1.6 1.123 2.994 2.707 3.227 1.087.16 2.185.283 3.293.369V21l4.184-4.183a1.14 1.14 0 0 1 .778-.332 48.294 48.294 0 0 0 5.83-.498c1.585-.233 2.708-1.626 2.708-3.228V6.741c0-1.602-1.123-2.995-2.707-3.228A48.394 48.394 0 0 0 12 3c-2.392 0-4.744.175-7.043.513C3.373 3.746 2.25 5.14 2.25 6.741v6.018Z" />
            </svg>
          <% end %>
        <% else %>
          <button type="button" class="item-header-icon-button" data-action="ai-chat-drawer#open">
            <span class="sr-only"><%= ai_chat_label %></span>
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true" class="size-6">
              <path stroke-linecap="round" stroke-linejoin="round" d="M8.625 9.75a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Zm0 0H8.25m4.125 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Zm0 0H12m4.125 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Zm0 0h-.375m-13.5 3.01c0 1.6 1.123 2.994 2.707 3.227 1.087.16 2.185.283 3.293.369V21l4.184-4.183a1.14 1.14 0 0 1 .778-.332 48.294 48.294 0 0 0 5.83-.498c1.585-.233 2.708-1.626 2.708-3.228V6.741c0-1.602-1.123-2.995-2.707-3.228A48.394 48.394 0 0 0 12 3c-2.392 0-4.744.175-7.043.513C3.373 3.746 2.25 5.14 2.25 6.741v6.018Z" />
            </svg>
          </button>
        <% end %>
      <% end %>

      <%# ---- dropdown ---- %>
      <% if overflow_actions.any? %>
      <details class="item-header-overflow">
          <summary class="item-header-overflow-button">
            <span class="sr-only"><%= overflow_label %></span>
            <svg viewBox="0 0 20 20" fill="currentColor" data-slot="icon" aria-hidden="true" class="size-5">
              <path d="M10 3a1.5 1.5 0 1 1 0 3 1.5 1.5 0 0 1 0-3ZM10 8.5a1.5 1.5 0 1 1 0 3 1.5 1.5 0 0 1 0-3ZM11.5 15.5a1.5 1.5 0 1 0-3 0 1.5 1.5 0 0 0 3 0Z" />
            </svg>
          </summary>

          <div class="item-header-overflow-menu">
            <div class="py-1">
              <% overflow_actions.each do |action| %>
                <% action_classes = class_names("item-header-overflow-item", "item-header-overflow-item-danger": action[:danger]) %>
                <% action_type = action[:type]&.to_sym || (action[:path].present? ? :link : :button) %>
                <% if action_type == :button %>
                  <%= button_tag type: "button", class: action_classes, data: action[:data] || {} do %>
                    <span><%= action.fetch(:label) %></span>
                  <% end %>
                <% elsif action[:method].present? && action[:method].to_sym != :get %>
                  <%= button_to action.fetch(:label),
                        action.fetch(:path),
                        method: action[:method],
                        class: action_classes,
                        form_class: "contents",
                        form: action[:form] || {} %>
                <% else %>
                  <%= link_to action.fetch(:label), action.fetch(:path), class: action_classes, data: action[:data] || {} %>
                <% end %>
              <% end %>
            </div>
          </div>
      </details>
      <% end %>
     </div>
    </div>
    </div>
  </div>

  <% if show_search_drawer %>
    <%= render layout: "components/drawer",
          locals: {
            controller: "search-drawer",
            title: search_drawer_title,
            title_id: "search-drawer-title"
          } do %>
      <p class="search-drawer-query" data-search-drawer-target="queryText"></p>
      <% if search_frame_id.present? %>
        <%= turbo_frame_tag search_frame_id do %>
          <% if search_frame_content.present? %>
            <%= search_frame_content %>
          <% else %>
            <p class="search-drawer-empty"><%= search_drawer_body %></p>
          <% end %>
        <% end %>
      <% else %>
        <p class="search-drawer-empty"><%= search_drawer_body %></p>
      <% end %>
    <% end %>
  <% end %>

  <% if show_ai_chat && ai_chat_path.blank? %>
    <%= render "components/ai_chat_drawer",
          drawer_title: ai_chat_drawer_title,
          drawer_body: ai_chat_drawer_body %>
  <% end %>
</header>
