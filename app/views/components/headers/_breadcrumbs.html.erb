<nav aria-label="Breadcrumb" class="mx-auto w-full max-w-7xl px-2 pt-3 sm:px-3 lg:px-4">
  <ol role="list" class="flex flex-wrap items-center gap-x-2 gap-y-1 text-sm text-neutral-500">
    <% breadcrumbs.each_with_index do |breadcrumb, index| %>
      <li class="flex min-w-0 items-center gap-2">
        <% if index.positive? %>
          <span aria-hidden="true" class="shrink-0 text-neutral-300">/</span>
        <% end %>

        <% if breadcrumb[:path].present? %>
          <%= link_to breadcrumb.fetch(:label),
                breadcrumb[:path],
                class: "break-words font-medium text-neutral-500 transition hover:text-cyan-950" %>
        <% else %>
          <span class="break-words font-medium text-neutral-950" aria-current="page">
            <%= breadcrumb.fetch(:label) %>
          </span>
        <% end %>
      </li>
    <% end %>
  </ol>
</nav>
