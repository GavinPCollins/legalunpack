<%# Sidebar contents are rendered in two shells:
    - mobile drawer in the application layout
    - fixed desktop sidebar in the application layout
    Keep navigation logic here; keep responsive drawer behaviour in the layout. %>
<div class="side-nav-inner">
  <%# ====== Logo section ====== %>
  <div class="mb-8 flex shrink-0 items-start px-2">

    <%= link_to root_path, aria: { label: "Legalunpack" }, class: "flex items-center justify-start gap-3 px-2 text-neutral-950" do %>
      <%= image_tag "Logo9.svg", alt: "Legalunpack", class: "h-12 w-auto max-w-full object-contain" %>
    <% end %>
  </div>

  <nav class="flex flex-1 flex-col" aria-label="Main navigation">
    <% packages_controller_active = controller_name == "packages" %>
    <% new_package_active = packages_controller_active && %w[new create].include?(action_name) %>
    <% packages_index_active = packages_controller_active && action_name == "index" %>
    <% selected_package_id = packages_controller_active && %w[show edit update].include?(action_name) ? params[:id].to_s : nil %>

    <%# ====== Nav - Parts ====== %>
    <%# Links keep labels visible in both shells.
        The whole sidebar is hidden on mobile until the drawer opens. %>
    <ul class="mt-4 space-y-1">
      <%# --- new package --- %>
      <li>
        <%= link_to new_package_path, aria: { label: "New package", current: (new_package_active ? "page" : nil) }, title: "New package", class: class_names(
          "group flex items-center gap-3 rounded-md px-3 py-2 text-sm font-semibold transition-colors",
          new_package_active ? "bg-neutral-50 text-neutral-950" : "text-neutral-700 hover:bg-neutral-50 hover:text-neutral-950"
        ) do %>
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true" class="size-5 shrink-0">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
          </svg>
          <span>New package</span>
        <% end %>
      </li>

      <%# CODEX search function updates %>
      <li>
        <%= link_to packages_path, aria: { label: "Search packages", current: (packages_index_active ? "page" : nil) }, title: "Search packages", class: class_names(
          "group flex items-center gap-3 rounded-md px-3 py-2 text-sm font-semibold transition-colors",
          packages_index_active ? "bg-neutral-50 text-neutral-950" : "text-neutral-700 hover:bg-neutral-50 hover:text-neutral-950"
        ) do %>
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true" class="size-5 shrink-0">
            <path stroke-linecap="round" stroke-linejoin="round" d="m21 21-4.35-4.35m1.35-5.4a6.75 6.75 0 1 1-13.5 0 6.75 6.75 0 0 1 13.5 0Z" />
          </svg>
          <span>Search packages</span>
        <% end %>
      </li>
    </ul>

    <%# CODEX package list updates %>
    <% sidebar_packages = current_user.packages.where.not(name: [nil, ""]).order(created_at: :desc) %>

    <%# ====== Collection (packages) ====== %>
    <% if sidebar_packages.any? %>
      <div class="pt-16 text-xs/6 font-semibold text-neutral-500">Packages</div>
      <ul role="list" class="-mx-2 space-y-1">
        <% sidebar_packages.each do |pack| %>
          <% package_active = selected_package_id == pack.id.to_s %>
          <li class="group relative flex items-center gap-1">
            <%= link_to package_path(pack), aria: { current: (package_active ? "page" : nil) }, class: class_names(
              "min-w-0 flex-1 rounded-md p-2 text-sm/6 font-medium",
              package_active ? "bg-neutral-50 text-neutral-950" : "text-neutral-700 hover:bg-neutral-50 hover:text-neutral-950"
            ) do %>
              <span class="truncate"><%= pack.name %></span>
            <% end %>

            <%# CODEX package actions updates %>
            <details class="relative shrink-0" data-controller="menu">
              <summary role="button" aria-haspopup="menu" aria-label="Package actions for <%= pack.name %>" title="Package actions" class="flex size-8 cursor-pointer list-none items-center justify-center rounded-md text-neutral-500 opacity-100 transition hover:bg-neutral-50 hover:text-neutral-950 focus:bg-neutral-50 focus:text-neutral-950 focus:outline-none lg:opacity-0 lg:group-hover:opacity-100 lg:focus-within:opacity-100 [&::-webkit-details-marker]:hidden">
                <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" class="size-5">
                  <circle cx="12" cy="5" r="1.6" />
                  <circle cx="12" cy="12" r="1.6" />
                  <circle cx="12" cy="19" r="1.6" />
                </svg>
              </summary>
              <div role="menu" class="absolute right-0 z-20 mt-1 w-40 rounded-md border border-neutral-200 bg-white py-1 shadow-sm">
                <%= link_to "Edit name", package_path(pack, edit: "name", anchor: "package-name"), role: "menuitem", class: "block px-3 py-2 text-sm font-medium text-neutral-700 hover:bg-cyan-50 hover:text-cyan-950" %>
                <%= button_to "Delete package", package_path(pack), method: :delete, role: "menuitem", form: { data: { turbo_confirm: "Delete #{pack.name}?" } }, class: "block w-full px-3 py-2 text-left text-sm font-medium text-red-700 hover:bg-red-50 hover:text-red-900" %>
              </div>
            </details>
          </li>
        <% end %>
      </ul>
    <% end %>

    <%# ====== Account ====== %>
    <%# Account controls stay at the bottom of both sidebar shells. %>
    <div class="mt-auto border-t border-neutral-200 pt-4">
      <div class="flex items-center gap-3 pb-3">
        <span class="flex size-9 shrink-0 items-center justify-center rounded-full bg-neutral-50 text-sm font-bold text-neutral-700 outline -outline-offset-1 outline-black/5">
          <%= (current_user.try(:name).presence || current_user.username.presence || current_user.email).first.upcase %>
        </span>
        <div class="min-w-0">
          <p class="truncate text-sm font-semibold text-neutral-950"><%= current_user.try(:name).presence || current_user.username.presence || "Account" %></p>
          <p class="truncate text-xs text-neutral-500"><%= current_user.email %></p>
        </div>
      </div>

      <%= link_to edit_user_registration_path, aria: { label: "Profile", current: (current_page?(edit_user_registration_path) ? "page" : nil) }, title: "Profile", class: class_names(
        "flex items-center gap-3 rounded-md px-3 py-2 text-sm font-medium transition-colors",
        current_page?(edit_user_registration_path) ? "bg-neutral-50 text-neutral-950" : "text-neutral-700 hover:bg-neutral-50 hover:text-neutral-950"
      ) do %>
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true" class="size-5 shrink-0">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0ZM4.501 20.118a7.5 7.5 0 0 1 14.998 0A17.933 17.933 0 0 1 12 21.75c-2.676 0-5.216-.584-7.499-1.632Z" />
        </svg>
        <span>Profile</span>
      <% end %>

      <%= button_to destroy_user_session_path, method: :delete, aria: { label: "Log out" }, title: "Log out", class: "flex w-full items-center gap-3 rounded-md px-3 py-2 text-left text-sm font-medium text-neutral-700 transition-colors hover:bg-neutral-50 hover:text-neutral-950" do %>
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true" class="size-5 shrink-0">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 9V5.25A2.25 2.25 0 0 0 13.5 3h-6a2.25 2.25 0 0 0-2.25 2.25v13.5A2.25 2.25 0 0 0 7.5 21h6a2.25 2.25 0 0 0 2.25-2.25V15m3 0 3-3m0 0-3-3m3 3H9" />
        </svg>
        <span>Log out</span>
      <% end %>
    </div>
  </nav>
</div>
