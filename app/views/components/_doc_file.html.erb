<%# ---- File status rules: tweak icon/state mapping here ---- %>
<%
  extraction_status = doc_file.extraction_status
  ai_status = doc_file.ai_status

  file_status =
    if extraction_status == "failed" || ai_status == "failed"
      :failed
    elsif ai_status == "complete"
      :complete
    elsif ai_status == "processing" || %w[pending processing].include?(extraction_status)
      :processing
    elsif extraction_status == "complete" && ai_status == "pending"
      :ready
    else
      :processing
    end

  status_is_live = file_status == :processing

  status_label =
    case file_status
    when :failed
      "Failed"
    when :complete
      "Complete"
    when :ready
      "Ready"
    else
      "Processing"
    end

  status_badge_classes =
    case file_status
    when :failed
      "bg-red-50 text-red-700 ring-red-600/20"
    when :complete
      "bg-green-50 text-green-700 ring-green-600/20"
    when :ready
      "bg-yellow-50 text-yellow-800 ring-yellow-600/20"
    else
      "bg-neutral-50 text-neutral-600 ring-neutral-500/10"
    end

  high_risk_clause_count =
    if doc_file.association(:clauses).loaded?
      doc_file.clauses.count { |clause| clause.risk_level == "high" }
    else
      doc_file.clauses.where(risk_level: "high").count
    end

  high_risk_clauses =
    if doc_file.association(:clauses).loaded?
      doc_file.clauses.select { |clause| clause.risk_level == "high" }
    else
      doc_file.clauses.where(risk_level: "high")
    end
%>

<%# ---- File micro-summary fallback text: tweak copy here ---- %>
<%
  file_micro_summary =
    if doc_file.ai_micro_summary.present?
      doc_file.ai_micro_summary
    elsif doc_file.ai_summary.present?
      doc_file.ai_summary
    elsif ai_status == "failed"
      "Summary failed"
    elsif extraction_status == "failed"
      "Text extraction failed"
    elsif ai_status == "processing"
      "Generating summary..."
    elsif extraction_status == "complete" && ai_status == "pending"
      "Ready for analysis"
    else
      "Extracting text..."
    end
%>

<li id="<%= dom_id(doc_file) %>"
    class="flex items-center justify-between gap-x-6 px-4 py-5"
    data-controller="status-poll clause-drawer"
    data-status-poll-url-value="<%= doc_file_path(doc_file) %>"
    data-status-poll-active-value="<%= status_is_live %>">
  <%# ---- Template section: left content mirrors Tailwind list item title + badge + metadata ---- %>
  <div class="min-w-0">
    <div class="flex min-w-0 items-start gap-x-3">
      <span class="mt-0.5 flex size-8 shrink-0 items-center justify-center rounded-md bg-cyan-50 text-cyan-800">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true" class="size-5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-5.1a2.25 2.25 0 0 0-.659-1.591l-3.9-3.9A2.25 2.25 0 0 0 13.35 3H6.75A2.25 2.25 0 0 0 4.5 5.25v13.5A2.25 2.25 0 0 0 6.75 21h10.5a2.25 2.25 0 0 0 2.25-2.25v-4.5Z" />
          <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 3.375V7.5A1.5 1.5 0 0 0 15 9h4.125" />
        </svg>
      </span>

      <div class="min-w-0">
        <div class="flex min-w-0 flex-wrap items-start gap-x-3 gap-y-1">
          <%# ---- Filename link: opens the per-file AI summary page ---- %>
          <% if doc_file.file.attached? %>
            <%= link_to doc_file.file.filename.to_s,
                  summary_doc_file_path(doc_file),
                  class: "block truncate text-sm font-semibold leading-6 text-neutral-950 hover:text-emerald-800" %>
          <% else %>
            <p class="truncate text-sm font-semibold leading-6 text-neutral-950">Untitled file</p>
          <% end %>

          <%# ---- Status badge: template pill, with our spinner/tick/cross/amber dash inside ---- %>
          <span class="inline-flex items-center gap-1 rounded-md px-1.5 py-0.5 text-xs font-medium ring-1 ring-inset <%= status_badge_classes %>" title="<%= status_label %>">
            <% if file_status == :processing %>
              <svg viewBox="0 0 24 24" fill="none" aria-hidden="true" class="size-3.5 animate-spin">
                <circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="2" class="opacity-25" />
                <path d="M21 12a9 9 0 0 0-9-9" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
              </svg>
            <% elsif file_status == :complete %>
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" aria-hidden="true" class="size-3.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="m5 13 4 4L19 7" />
              </svg>
            <% elsif file_status == :failed %>
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" aria-hidden="true" class="size-3.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M6 6l12 12M18 6 6 18" />
              </svg>
            <% else %>
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" aria-hidden="true" class="size-3.5">
                <path stroke-linecap="round" d="M6 12h12" />
              </svg>
            <% end %>
            <span><%= status_label %></span>
          </span>
        </div>

        <%# ---- Metadata row: adapted from template's due date / creator line ---- %>
        <div class="mt-1 flex min-w-0 flex-wrap items-center gap-x-2 gap-y-1 text-xs leading-5 text-neutral-500">
          <% if doc_file.file.attached? %>
            <p class="whitespace-nowrap"><%= number_to_human_size(doc_file.file.byte_size) %></p>
            <svg viewBox="0 0 2 2" class="size-0.5 fill-current" aria-hidden="true">
              <circle r="1" cx="1" cy="1" />
            </svg>
          <% end %>
          <p class="truncate text-neutral-600"><%= file_micro_summary %></p>
          <% if ai_status == "complete" %>
            <svg viewBox="0 0 2 2" class="size-0.5 fill-current" aria-hidden="true">
              <circle r="1" cx="1" cy="1" />
            </svg>

            <%# ---- High-risk drawer trigger: opens details when any high-risk clauses exist ---- %>
            <% if high_risk_clause_count.positive? %>
              <button type="button" class="cursor-pointer whitespace-nowrap font-medium text-red-700 hover:text-red-900" data-action="clause-drawer#open">
                <%= pluralize(high_risk_clause_count, "high-risk clause") %>
              </button>
            <% else %>
              <p class="whitespace-nowrap text-neutral-500"><%= pluralize(high_risk_clause_count, "high-risk clause") %></p>
            <% end %>
          <% end %>
        </div>
      </div>
    </div>
  </div>

  <%# ---- Template section: right actions, kept as Rails links/buttons instead of Tailwind Plus dropdown ---- %>
  <div class="flex flex-none items-center gap-x-2">
    <% if doc_file.file.attached? %>
      <%= link_to "Download", rails_blob_path(doc_file.file, disposition: "attachment"), class: "rounded-md bg-white px-2.5 py-1.5 text-sm font-semibold text-neutral-900 shadow-sm ring-1 ring-inset ring-neutral-300 hover:bg-neutral-50" %>
    <% end %>
    <%= button_to "Remove", doc_file_path(doc_file), method: :delete, class: "rounded-md px-2.5 py-1.5 text-sm font-semibold text-cyan-800 hover:bg-red-50" %>
  </div>

  <%# ---- High-risk clauses drawer: tweak the panel content/layout here ---- %>
  <% if high_risk_clause_count.positive? %>
    <dialog aria-labelledby="<%= dom_id(doc_file, :high_risk_title) %>" class="fixed inset-0 h-auto max-h-none w-auto max-w-none overflow-hidden bg-transparent backdrop:bg-transparent" data-clause-drawer-target="dialog">
      <div tabindex="0" class="absolute inset-0 pl-10 focus:outline-none sm:pl-16">
        <div class="ml-auto block h-full w-full max-w-2xl">
          <div class="relative flex h-full flex-col overflow-y-auto bg-white px-4 py-6 shadow-xl sm:px-6">
            <div class="flex items-start justify-between gap-4">
              <div>
                <h2 id="<%= dom_id(doc_file, :high_risk_title) %>" class="text-base font-semibold text-neutral-950">
                  High-risk clauses
                </h2>
                <p class="mt-1 text-sm text-neutral-500">
                  <%= doc_file.file.attached? ? doc_file.file.filename.to_s : "Untitled file" %>
                </p>
              </div>

              <button type="button" class="relative rounded-md text-neutral-400 hover:text-neutral-600" data-action="clause-drawer#close">
                <span class="absolute -inset-2.5"></span>
                <span class="sr-only">Close panel</span>
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true" class="size-6">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" />
                </svg>
              </button>
            </div>

            <ol class="mt-6 space-y-4">
              <% high_risk_clauses.sort_by { |clause| clause.position || 0 }.each do |clause| %>
                <li class="rounded-md border border-red-200 bg-red-50 p-4">
                  <p class="text-sm font-semibold text-red-900">
                    <%= clause.position.present? ? "#{clause.position}. " : "" %><%= clause.title.presence || "Untitled clause" %>
                  </p>
                  <p class="mt-2 text-sm leading-6 text-red-800">
                    <%= clause.summary.presence || "No summary saved." %>
                  </p>
                  <% if clause.content.present? %>
                    <details class="mt-3">
                      <summary class="cursor-pointer text-xs font-semibold text-red-800 hover:text-red-950">View clause text</summary>
                      <pre class="mt-2 whitespace-pre-wrap text-xs leading-5 text-red-900"><%= clause.content %></pre>
                    </details>
                  <% end %>
                </li>
              <% end %>
            </ol>
          </div>
        </div>
      </div>
    </dialog>
  <% end %>
</li>
