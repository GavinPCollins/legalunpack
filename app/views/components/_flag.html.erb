<% status_classes = flag.resolved? ? "border-emerald-200 bg-emerald-50 text-emerald-950" : "border-amber-200 bg-amber-50 text-amber-950" %>
<% badge_classes = flag.resolved? ? "bg-emerald-100 text-emerald-800" : "bg-amber-100 text-amber-800" %>

<li id="<%= dom_id(flag) %>" class="rounded-md border px-3 py-3 <%= status_classes %>">
  <div class="flex flex-col gap-3">
    <div class="min-w-0">
      <div class="flex flex-wrap items-center gap-2">
        <p class="text-sm font-semibold"><%= flag.name %></p>
        <span class="rounded-full px-2 py-0.5 text-xs font-semibold <%= badge_classes %>">
          <%= flag.level.present? ? "#{flag.level.humanize} priority" : "Review" %>
        </span>
        <% if flag.category.present? %>
          <span class="rounded-full bg-white/70 px-2 py-0.5 text-xs font-semibold">
            <%= flag.category.humanize %>
          </span>
        <% end %>
        <% if flag.resolved? %>
          <span class="rounded-full bg-white/70 px-2 py-0.5 text-xs font-semibold text-emerald-800">
            Resolved
          </span>
        <% end %>
      </div>

      <% if flag.reason.present? %>
        <p class="mt-1 text-sm leading-5"><%= flag.reason %></p>
      <% end %>

      <% if flag.suggested_action.present? %>
        <div class="mt-3 rounded-md bg-white/60 p-3 text-sm leading-5">
          <p class="font-semibold">Suggested action</p>
          <p class="mt-1"><%= flag.suggested_action %></p>
        </div>
      <% end %>

      <% if flag.resolved? && flag.resolution_note.present? %>
        <div class="mt-3 rounded-md bg-white/60 p-3 text-sm leading-5">
          <p class="font-semibold">Resolution note</p>
          <p class="mt-1"><%= flag.resolution_note %></p>
        </div>
      <% end %>
    </div>

    <% if flag.resolved? %>
      <%= button_to "Reopen",
            flag_path(flag),
            method: :patch,
            params: { flag: { resolved: false } },
            class: "inline-flex w-fit shrink-0 items-center justify-center rounded-md bg-white px-3 py-1.5 text-sm font-semibold text-neutral-900 shadow-sm ring-1 ring-inset ring-black/10 hover:bg-neutral-50" %>
    <% else %>
      <%= form_with model: flag, url: flag_path(flag), method: :patch, class: "rounded-md bg-white/50 p-3" do |form| %>
        <%= form.hidden_field :resolved, value: true %>
        <%= form.label :resolution_note, "Resolution note", class: "block text-xs font-semibold uppercase" %>
        <%= form.text_area :resolution_note,
              rows: 2,
              placeholder: "Confirmed, accepted, added to negotiation list...",
              class: "mt-2 block w-full rounded-md border-0 px-3 py-2 text-sm text-neutral-900 shadow-sm ring-1 ring-inset ring-black/10 placeholder:text-neutral-400 focus:ring-2 focus:ring-inset focus:ring-cyan-700" %>
        <%= form.submit "Resolve",
              class: "mt-3 inline-flex shrink-0 items-center justify-center rounded-md bg-white px-3 py-1.5 text-sm font-semibold text-neutral-900 shadow-sm ring-1 ring-inset ring-black/10 hover:bg-neutral-50" %>
      <% end %>
    <% end %>
  </div>
</li>
