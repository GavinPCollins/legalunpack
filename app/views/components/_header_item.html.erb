<%# ---- Search ---- %>
<% search_path = local_assigns[:search_path] || "#" %>
<% search_method = local_assigns[:search_method] || :get %>
<% search_name = local_assigns[:search_name] || :search %>
<% search_value = local_assigns[:search_value] %>
<% search_placeholder = local_assigns[:search_placeholder] || "Search" %>
<% search_label = local_assigns[:search_label] || search_placeholder %>

<%# ---- Notifications ---- %>
<% notification_label = local_assigns[:notification_label] || "View notifications" %>
<% notification_path = local_assigns[:notification_path] %>
<% show_notifications = local_assigns.fetch(:show_notifications, true) %>

<%# ---- Profile ---- %>
<% profile_name = local_assigns[:profile_name] || current_user.try(:name).presence || current_user.try(:username).presence || "Account" %>
<% profile_image_url = local_assigns[:profile_image_url] %>
<% profile_initial = profile_name.first.to_s.upcase %>
<% profile_links = local_assigns[:profile_links] || [] %>

<%# ---- Layout ---- %>
<% show_mobile_separator = local_assigns.fetch(:show_mobile_separator, true) %>

<header class="flex h-16 shrink-0 items-center gap-x-4 border-b border-gray-200 bg-white px-4 shadow-sm sm:gap-x-6 sm:px-6 lg:px-8">
  <%# ---- Mobile separator ---- %>
  <% if show_mobile_separator %>
    <div aria-hidden="true" class="h-6 w-px bg-gray-200 lg:hidden dark:bg-gray-700"></div>
  <% end %>

  <div class="flex flex-1 gap-x-4 self-stretch lg:gap-x-6">
    <%# ---- Search form ---- %>
    <%= form_with url: search_path, method: search_method, class: "grid flex-1 grid-cols-1" do %>
      <%= search_field_tag search_name,
            search_value,
            placeholder: search_placeholder,
            aria: { label: search_label },
            class: "col-start-1 row-start-1 block size-full bg-white pl-8 text-base text-gray-900 outline-hidden placeholder:text-gray-400 sm:text-sm/6 dark:bg-gray-900 dark:text-white dark:placeholder:text-gray-500" %>
      <svg viewBox="0 0 20 20" fill="currentColor" data-slot="icon" aria-hidden="true" class="pointer-events-none col-start-1 row-start-1 size-5 self-center text-gray-400">
        <path d="M9 3.5a5.5 5.5 0 1 0 0 11 5.5 5.5 0 0 0 0-11ZM2 9a7 7 0 1 1 12.452 4.391l3.328 3.329a.75.75 0 1 1-1.06 1.06l-3.329-3.328A7 7 0 0 1 2 9Z" clip-rule="evenodd" fill-rule="evenodd" />
      </svg>
    <% end %>

    <div class="flex items-center gap-x-4 lg:gap-x-6">
      <%# ---- Notifications button ---- %>
      <% if show_notifications %>
        <% if notification_path.present? %>
          <%= link_to notification_path, class: "-m-2.5 p-2.5 text-gray-400 hover:text-gray-500 dark:hover:text-white" do %>
            <span class="sr-only"><%= notification_label %></span>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" data-slot="icon" aria-hidden="true" class="size-6">
              <path d="M14.857 17.082a23.848 23.848 0 0 0 5.454-1.31A8.967 8.967 0 0 1 18 9.75V9A6 6 0 0 0 6 9v.75a8.967 8.967 0 0 1-2.312 6.022c1.733.64 3.56 1.085 5.455 1.31m5.714 0a24.255 24.255 0 0 1-5.714 0m5.714 0a3 3 0 1 1-5.714 0" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
          <% end %>
        <% else %>
          <button type="button" class="-m-2.5 p-2.5 text-gray-400 hover:text-gray-500 dark:hover:text-white">
            <span class="sr-only"><%= notification_label %></span>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" data-slot="icon" aria-hidden="true" class="size-6">
              <path d="M14.857 17.082a23.848 23.848 0 0 0 5.454-1.31A8.967 8.967 0 0 1 18 9.75V9A6 6 0 0 0 6 9v.75a8.967 8.967 0 0 1-2.312 6.022c1.733.64 3.56 1.085 5.455 1.31m5.714 0a24.255 24.255 0 0 1-5.714 0m5.714 0a3 3 0 1 1-5.714 0" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
          </button>
        <% end %>
      <% end %>

      <%# ---- Desktop separator ---- %>
      <div aria-hidden="true" class="hidden lg:block lg:h-6 lg:w-px lg:bg-gray-200 dark:lg:bg-white/10"></div>

      <%# ---- Profile dropdown ---- %>
      <details class="relative">
        <summary class="relative flex cursor-pointer list-none items-center [&::-webkit-details-marker]:hidden">
          <span class="absolute -inset-1.5"></span>
          <span class="sr-only">Open user menu</span>
          <% if profile_image_url.present? %>
            <%= image_tag profile_image_url, alt: "", class: "size-8 rounded-full bg-gray-50 outline -outline-offset-1 outline-black/5 dark:bg-gray-800 dark:outline-white/10" %>
          <% else %>
            <span class="flex size-8 items-center justify-center rounded-full bg-gray-50 text-sm font-semibold text-gray-700 outline -outline-offset-1 outline-black/5 dark:bg-gray-800 dark:text-white dark:outline-white/10">
              <%= profile_initial %>
            </span>
          <% end %>
          <span class="hidden lg:flex lg:items-center">
            <span aria-hidden="true" class="ml-4 text-sm/6 font-semibold text-gray-900 dark:text-white"><%= profile_name %></span>
            <svg viewBox="0 0 20 20" fill="currentColor" data-slot="icon" aria-hidden="true" class="ml-2 size-5 text-gray-400">
              <path d="M5.22 8.22a.75.75 0 0 1 1.06 0L10 11.94l3.72-3.72a.75.75 0 1 1 1.06 1.06l-4.25 4.25a.75.75 0 0 1-1.06 0L5.22 9.28a.75.75 0 0 1 0-1.06Z" clip-rule="evenodd" fill-rule="evenodd" />
            </svg>
          </span>
        </summary>

        <% if profile_links.any? %>
          <div class="absolute right-0 z-20 mt-2 w-36 origin-top-right rounded-md bg-white py-2 shadow-lg outline-1 outline-gray-900/5 dark:bg-gray-800 dark:shadow-none dark:-outline-offset-1 dark:outline-white/10">
            <% profile_links.each do |profile_link| %>
              <% profile_method = profile_link[:method] || :get %>
              <% if profile_method == :get %>
                <%= link_to profile_link.fetch(:label), profile_link.fetch(:path), class: "block px-3 py-1 text-sm/6 text-gray-900 focus:bg-gray-50 focus:outline-hidden dark:text-white dark:focus:bg-gray-700" %>
              <% else %>
                <%= button_to profile_link.fetch(:label), profile_link.fetch(:path), method: profile_method, class: "block w-full px-3 py-1 text-left text-sm/6 text-gray-900 focus:bg-gray-50 focus:outline-hidden dark:text-white dark:focus:bg-gray-700" %>
              <% end %>
            <% end %>
          </div>
        <% end %>
      </details>
    </div>
  </div>
</header>
