<% render_context = local_assigns[:render_context] || "action_item" %>
<% dialog_name = dom_id(flag, :dismiss_dialog) %>

<div class="flex justify-center" data-controller="modal">
  <button type="button"
          class="rounded-md px-3 py-2 text-sm font-semibold text-red-700 hover:bg-red-50 hover:text-red-900"
          data-action="modal#open">
    Dismiss flag
  </button>

  <div class="fixed inset-0 z-[100] hidden"
       role="dialog"
       aria-modal="true"
       aria-labelledby="<%= dialog_name %>-title"
       data-modal-target="dialog">
    <div class="fixed inset-0 bg-neutral-950/40"
         aria-hidden="true"
         data-action="click->modal#close"></div>

    <div class="fixed inset-0 z-10 flex items-center justify-center p-4">
      <div class="w-full max-w-md rounded-lg bg-white p-6 text-left shadow-xl">
        <h2 id="<%= dialog_name %>-title" class="text-lg font-semibold text-neutral-950">
          Dismiss flag
        </h2>
        <p class="mt-1 text-sm text-neutral-600">
          This flag will be removed from unresolved flags.
        </p>

        <%= form_with model: flag,
              url: flag_path(flag),
              method: :patch,
              class: "mt-6" do |form| %>
          <%= hidden_field_tag :render_context, render_context %>
          <%= form.hidden_field :resolved, value: true %>

          <%= form.label :resolution_note,
                "Reason (optional)",
                class: "block text-sm font-semibold text-neutral-950" %>
          <%= form.text_area :resolution_note,
                rows: 3,
                placeholder: "Add a reason for dismissing this flag...",
                class: "mt-2 block w-full rounded-md border border-neutral-300 bg-white px-3 py-2 text-sm text-neutral-900 shadow-sm placeholder:text-neutral-400 focus:border-cyan-700 focus:outline-none focus:ring-1 focus:ring-cyan-700" %>

          <div class="mt-6 flex justify-end gap-3">
            <button type="button"
                    class="btn btn-secondary"
                    data-action="modal#close">
              Cancel
            </button>
            <%= form.submit "Dismiss flag",
                  class: "rounded-md bg-red-700 px-3 py-2 text-sm font-semibold text-white shadow-sm hover:bg-red-800" %>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>
