<% clause = flag.clause %>
<% render_context = local_assigns[:render_context] || "action_item" %>
<% priority_label = flag.level.present? ? "#{flag.level.humanize} priority" : "Review" %>
<%
  priority_class =
    case flag.level
    when "high"
      "badge-danger"
    when "medium"
      "badge-warning"
    when "low"
      "badge-info"
    else
      "badge-neutral"
    end
%>
<% drawer_title = capture do %>
  <span class="flex flex-wrap items-center gap-2">
    <span><%= flag.name %></span>
    <span class="pill <%= priority_class %>"><%= priority_label %></span>
  </span>
<% end %>
<% drawer_footer = capture do %>
  <%= render "components/flag_footer", flag: flag, render_context: render_context %>
<% end %>

<%= render layout: "components/drawer",
      locals: {
        controller: "flag-drawer",
        title: drawer_title,
        title_id: dom_id(flag, :drawer_title),
        subtitle: file_name,
        dialog_class: "fixed inset-0 h-auto max-h-none w-auto max-w-none overflow-hidden bg-transparent backdrop:bg-transparent",
        shell_class: "absolute inset-0 pl-10 focus:outline-none sm:pl-16",
        panel_class: "ml-auto block h-full w-full max-w-2xl",
        content_class: "relative flex h-full flex-col overflow-hidden bg-white px-4 py-6 shadow-xl sm:px-6",
        header_class: "flex shrink-0 items-start justify-between gap-4",
        title_class: "text-base font-semibold text-neutral-950",
        subtitle_class: "mt-1 text-sm text-neutral-500",
        close_wrap_class: "",
        close_button_class: "relative rounded-md text-neutral-400 hover:text-neutral-600",
        body_class: "mt-6 flex-1 overflow-y-auto pb-6",
        footer: drawer_footer,
        footer_class: "sticky bottom-0 shrink-0 border-t border-neutral-200 bg-white pt-4"
      } do %>
  <%= render "components/flag_detail", flag: flag, render_context: render_context %>
<% end %>
