<% clause = flag.clause %>
<% render_context = local_assigns[:render_context] || "action_item" %>
<% priority_label = flag.level.present? ? "#{flag.level.humanize} priority" : "Review" %>
<%
  priority_class =
    case flag.level
    when "high"
      "badge-danger"
    when "medium"
      "badge-warning"
    when "low"
      "badge-info"
    else
      "badge-neutral"
    end
%>
<% drawer_title = capture do %>
  <span class="flex flex-wrap items-center gap-2">
    <span><%= flag.name %></span>
    <span class="pill <%= priority_class %>"><%= priority_label %></span>
  </span>
<% end %>

<%= render layout: "components/drawer",
      locals: {
        controller: "flag-drawer",
        title: drawer_title,
        title_id: dom_id(flag, :drawer_title),
        subtitle: file_name,
        dialog_class: "fixed inset-0 h-auto max-h-none w-auto max-w-none overflow-hidden bg-transparent backdrop:bg-transparent",
        shell_class: "absolute inset-0 pl-10 focus:outline-none sm:pl-16",
        panel_class: "ml-auto block h-full w-full max-w-2xl",
        content_class: "relative flex h-full flex-col overflow-hidden bg-white px-4 py-6 shadow-xl sm:px-6",
        header_class: "flex shrink-0 items-start justify-between gap-4",
        title_class: "text-base font-semibold text-neutral-950",
        subtitle_class: "mt-1 text-sm text-neutral-500",
        close_wrap_class: "",
        close_button_class: "relative rounded-md text-neutral-400 hover:text-neutral-600",
        body_class: "mt-6 flex-1 overflow-y-auto"
      } do %>
  <div class="space-y-6">
    <dl class="grid grid-cols-1 gap-4 sm:grid-cols-2">
      <div>
        <dt class="text-xs font-semibold uppercase tracking-wide text-neutral-500">Category</dt>
        <dd class="mt-1 text-sm text-neutral-950"><%= flag.category.present? ? flag.category.humanize : "Not set" %></dd>
      </div>
      <div>
        <dt class="text-xs font-semibold uppercase tracking-wide text-neutral-500">Status</dt>
        <dd class="mt-1 text-sm text-neutral-950"><%= flag.resolved? ? "Resolved" : "Open" %></dd>
      </div>
      <div>
        <dt class="text-xs font-semibold uppercase tracking-wide text-neutral-500">Clause</dt>
        <dd class="mt-1 text-sm text-neutral-950">
          <%= clause.position.present? ? "#{clause.position}. " : "" %><%= clause.title.presence || "Untitled clause" %>
        </dd>
      </div>
    </dl>

    <% if flag.reason.present? %>
      <section>
        <h3 class="text-sm font-semibold text-neutral-950">Reason</h3>
        <p class="mt-2 whitespace-pre-wrap text-sm leading-6 text-neutral-700"><%= flag.reason %></p>
      </section>
    <% end %>

    <% if flag.suggested_action.present? %>
      <section class="rounded-md bg-neutral-50 p-4">
        <h3 class="text-sm font-semibold text-neutral-950">Suggested action</h3>
        <p class="mt-2 whitespace-pre-wrap text-sm leading-6 text-neutral-700"><%= flag.suggested_action %></p>
      </section>
    <% end %>

    <% if clause.summary.present? %>
      <section>
        <h3 class="text-sm font-semibold text-neutral-950">Clause summary</h3>
        <p class="mt-2 whitespace-pre-wrap text-sm leading-6 text-neutral-700"><%= clause.summary %></p>
      </section>
    <% end %>

    <% if clause.content.present? %>
      <details>
        <summary class="cursor-pointer text-sm font-semibold text-cyan-800 hover:text-cyan-950">View clause text</summary>
        <pre class="mt-2 whitespace-pre-wrap text-sm leading-6 text-neutral-700"><%= clause.content %></pre>
      </details>
    <% end %>

    <% if flag.resolved? %>
      <% if flag.resolution_note.present? %>
        <section class="rounded-md bg-emerald-50 p-4">
          <h3 class="text-sm font-semibold text-emerald-950">Resolution note</h3>
          <p class="mt-2 whitespace-pre-wrap text-sm leading-6 text-emerald-900"><%= flag.resolution_note %></p>
        </section>
      <% end %>

      <%= button_to "Reopen",
            flag_path(flag),
            method: :patch,
            params: { flag: { resolved: false }, render_context: render_context },
            class: "btn btn-secondary" %>
    <% else %>
      <%= form_with model: flag, url: flag_path(flag), method: :patch, class: "rounded-md border border-neutral-200 p-4" do |form| %>
        <%= form.hidden_field :resolved, value: true %>
        <%= hidden_field_tag :render_context, render_context %>
        <%= form.label :resolution_note, class: "block text-sm font-semibold text-neutral-950" do %>
          Resolution note <span class="font-normal text-neutral-500">(optional)</span>
        <% end %>
        <%= form.text_area :resolution_note,
              rows: 3,
              placeholder: "Confirmed, accepted, added to negotiation list...",
              class: "mt-2 block w-full rounded-md border border-neutral-300 bg-white px-3 py-2 text-sm text-neutral-900 shadow-sm placeholder:text-neutral-400 focus:border-cyan-700 focus:outline-none focus:ring-1 focus:ring-cyan-700" %>
        <%= form.submit "Resolve", class: "btn btn-primary mt-3" %>
      <% end %>
    <% end %>
  </div>
<% end %>
