<%
  file_name =
    if local_assigns[:file_name].present?
      local_assigns[:file_name]
    elsif flag.clause.doc_file&.file&.attached?
      flag.clause.doc_file.file.filename.to_s
    else
      "Untitled file"
    end
%>

<div id="<%= dom_id(flag) %>" class="inline-flex" data-controller="flag-drawer">
  <button type="button"
          class="rounded-md p-1 text-red-700 transition hover:bg-red-50 hover:text-red-900"
          aria-label="View flag: <%= flag.name %>"
          title="<%= flag.name %>"
          data-action="flag-drawer#open">
    <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" class="size-4">
      <path fill-rule="evenodd" d="M3 2.25a.75.75 0 0 1 .75.75v.54l2.202-.55a9.75 9.75 0 0 1 6.726.739l.108.054a8.25 8.25 0 0 0 5.579.651l2.963-.697a.75.75 0 0 1 .92.789 49.288 49.288 0 0 0 .005 10.338.75.75 0 0 1-.574.797l-3.114.732a9.75 9.75 0 0 1-6.593-.77l-.108-.054a8.25 8.25 0 0 0-5.69-.625l-2.424.606V21a.75.75 0 0 1-1.5 0V3A.75.75 0 0 1 3 2.25Z" clip-rule="evenodd" />
    </svg>
  </button>

  <%= render "components/flag_drawer", flag: flag, file_name: file_name, render_context: "icon_trigger" %>
</div>
