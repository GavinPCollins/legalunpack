<details class="group mt-5 border-t border-neutral-200 pt-4" data-archived-files>
  <summary class="flex w-fit cursor-pointer list-none items-center gap-1 rounded-md px-1 py-2 text-sm font-semibold text-neutral-600 hover:bg-neutral-50 hover:text-neutral-950 [&::-webkit-details-marker]:hidden">
    <span>Archived files (<%= doc_files.count %>)</span>
    <svg viewBox="0 0 20 20"
         fill="currentColor"
         aria-hidden="true"
         class="size-5 shrink-0 text-neutral-600 transition-transform group-open:rotate-90">
      <path fill-rule="evenodd" d="M8.22 5.22a.75.75 0 0 1 1.06 0l4.25 4.25a.75.75 0 0 1 0 1.06l-4.25 4.25a.75.75 0 1 1-1.06-1.06L11.94 10 8.22 6.28a.75.75 0 0 1 0-1.06Z" clip-rule="evenodd" />
    </svg>
  </summary>

  <ul role="list" class="mt-2 divide-y divide-neutral-200">
    <% doc_files.each do |doc_file| %>
      <% file_name = doc_file.file.attached? ? doc_file.file.filename.to_s : "Untitled file" %>
      <% replacement_name =
           if doc_file.replaced_by_doc_file&.file&.attached?
             doc_file.replaced_by_doc_file.file.filename.to_s
           elsif doc_file.replaced_by_doc_file.present?
             "Untitled file"
           end %>

      <li class="py-4">
        <p class="text-xs leading-5 text-neutral-500">
          Archived
          <time datetime="<%= doc_file.archived_at.iso8601 %>"><%= doc_file.archived_at.to_date.to_fs(:long) %></time>
        </p>

        <div class="mt-0.5 flex items-center justify-between gap-3">
          <p class="min-w-0 truncate text-sm font-medium italic leading-6 text-neutral-600"><%= file_name %></p>

          <% if doc_file.file.attached? %>
            <%= link_to rails_blob_path(doc_file.file, disposition: "attachment"),
                  class: "flex shrink-0 items-center justify-center rounded-md p-1 text-neutral-700 hover:bg-neutral-100 hover:text-neutral-950",
                  title: "Download #{file_name}",
                  aria: { label: "Download #{file_name}" } do %>
              <svg xmlns="http://www.w3.org/2000/svg"
                   viewBox="0 0 20 20"
                   fill="currentColor"
                   aria-hidden="true"
                   class="size-5">
                <path d="M10.75 2.75a.75.75 0 0 0-1.5 0v8.614L6.295 8.235a.75.75 0 1 0-1.09 1.03l4.25 4.5a.75.75 0 0 0 1.09 0l4.25-4.5a.75.75 0 0 0-1.09-1.03l-2.955 3.129V2.75Z" />
                <path d="M3.5 12.75a.75.75 0 0 0-1.5 0v2.5A2.75 2.75 0 0 0 4.75 18h10.5A2.75 2.75 0 0 0 18 15.25v-2.5a.75.75 0 0 0-1.5 0v2.5c0 .69-.56 1.25-1.25 1.25H4.75c-.69 0-1.25-.56-1.25-1.25v-2.5Z" />
              </svg>
            <% end %>
          <% end %>
        </div>

        <% if replacement_name.present? %>
          <p class="mt-0.5 text-xs leading-5 text-neutral-500">
            replaced with <span class="font-medium"><%= replacement_name %></span>
          </p>
        <% end %>
      </li>
    <% end %>
  </ul>
</details>
