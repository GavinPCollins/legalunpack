<%# CODEX file summary %>

<% file_title = @doc_file.file.attached? ? @doc_file.file.filename.to_s : "Untitled file" %>
<% summary_text = @doc_file.ai_summary.presence || "No AI summary saved yet." %>
<% focused_clause_highlight = @highlight_clause_id.present? %>

<div class="page-item" data-controller="summary-highlight">
  <%= render "components/headers/header_item",
        item_title: file_title,
        breadcrumbs: [
          { label: @package.name.presence || "Untitled package", path: package_path(@package) }
        ],
        search_path: summary_search_doc_files_path,
        search_name: :q,
        search_params: { package_id: @package.id },
        search_placeholder: "Search this package",
        search_drawer_title: "Package search",
        search_drawer_body: "Press Return to search this package.",
        search_frame_id: "summary_search_results",
        ai_chat_url: package_chatbot_sessions_path(@package),
        overflow_actions: [
          { label: "Rename package", type: :button, data: { action: "modal#open", modal_dialog_param: "rename" } },
          { label: "Add documents", type: :button, data: { action: "modal#open", modal_dialog_param: "documents" } },
          {
            label: "Delete package",
            path: package_path(@package),
            method: :delete,
            danger: true,
            form: { data: { turbo_confirm: "Delete #{@package.name.presence || "this package"}?" } }
          }]
 %>

  <% file_panel = capture do %>
    <div class="space-y-4 border-l border-neutral-200 pl-6">
      <section class="rounded-md border border-neutral-200 bg-white p-4">
        <h2 class="text-sm font-semibold text-neutral-950">File details</h2>
        <dl class="mt-4 space-y-3 text-sm">
          <div>
            <dt class="font-medium text-neutral-950">Package</dt>
            <dd class="mt-1 text-neutral-600"><%= @package.name.presence || "Untitled package" %></dd>
          </div>
          <div>
            <dt class="font-medium text-neutral-950">Extraction</dt>
            <dd class="mt-1 text-neutral-600"><%= @doc_file.extraction_status %></dd>
          </div>
          <div>
            <dt class="font-medium text-neutral-950">AI status</dt>
            <dd class="mt-1 text-neutral-600"><%= @doc_file.ai_status %></dd>
          </div>
          <div>
            <dt class="font-medium text-neutral-950">Clauses</dt>
            <dd class="mt-1 text-neutral-600"><%= @doc_file.clauses.count %></dd>
          </div>
        </dl>
      </section>

      <% if @doc_file.clauses.any? %>
        <nav class="rounded-md border border-neutral-200 bg-white p-4" aria-label="Document clauses">
          <h2 class="text-sm font-semibold text-neutral-950">Jump to clause</h2>
          <ol class="mt-3 space-y-2 text-sm">
            <% @doc_file.clauses.sort_by { |clause| clause.position || 0 }.each do |clause| %>
              <li>
                <a href="#clause-<%= clause.id %>" class="block text-cyan-800 hover:text-cyan-950">
                  <%= clause.position %>. <%= clause.title.presence || "Untitled clause" %>
                </a>
              </li>
            <% end %>
          </ol>
        </nav>
      <% end %>
    </div>
  <% end %>

  <%= render layout: "layouts/details_page", locals: { panel: file_panel } do %>
    <section class="content">
      <header class="border-b border-neutral-200 pb-4">
        <h2 class="text-lg font-semibold text-neutral-950"><%= file_title %></h2>

        <p class="mt-1 text-sm text-neutral-600">
          Extraction: <%= @doc_file.extraction_status %> |
          AI: <%= @doc_file.ai_status %>
        </p>
      </header>

      <% if @doc_file.ai_error.present? %>
        <div class="mt-4 rounded-md border border-red-200 bg-red-50 p-3">
          <p class="text-sm font-semibold text-red-700">AI error</p>
          <pre class="mt-2 whitespace-pre-wrap text-sm text-red-700"><%= @doc_file.ai_error %></pre>
        </div>
      <% end %>

      <h3 class="mt-5 text-sm font-semibold text-neutral-950">File summary</h3>

      <div id="file-summary" class="scroll-mt-24">
        <p class="mt-2 whitespace-pre-wrap text-sm text-neutral-700"><%= @highlight_query.present? && !focused_clause_highlight ? highlighted_summary_text(summary_text, @highlight_query) : summary_text %></p>
      </div>

      <div class="mt-5">
        <h3 class="text-sm font-semibold text-neutral-950">Clauses</h3>

        <% if @doc_file.clauses.any? %>
          <ol class="mt-3 space-y-4">
            <% @doc_file.clauses.sort_by { |clause| clause.position || 0 }.each do |clause| %>
              <% focused_clause = focused_clause_highlight && @highlight_clause_id == clause.id.to_s %>
              <% clause_highlight_query = @highlight_query.present? && (!focused_clause_highlight || @highlight_clause_id == clause.id.to_s) ? @highlight_query : nil %>
              <% clause_title = clause.title.presence || "Untitled clause" %>
              <% clause_summary = clause.summary.presence || "No summary saved." %>
              <li id="<%= dom_id(clause) %>" class="<%= class_names(
                "scroll-mt-24 rounded-md border p-4",
                focused_clause ? "border-cyan-300 bg-cyan-50/40 ring-2 ring-cyan-100" : "border-neutral-200"
              ) %>">
                <div class="flex items-start justify-between gap-3">
                  <p class="min-w-0 text-sm font-semibold text-neutral-950">
                    <%= clause.position %>. <%= clause_highlight_query.present? ? highlighted_summary_text(clause_title, clause_highlight_query) : clause_title %>
                  </p>

                  <% if clause.flags.any? %>
                    <div class="flex shrink-0 flex-wrap items-center justify-end gap-1">
                      <% clause.flags.each do |flag| %>
                        <%= render "components/flag_icon_trigger", flag: flag, file_name: file_title %>
                      <% end %>
                    </div>
                  <% end %>
                </div>

                <p class="mt-3 text-sm font-medium text-neutral-800">Summary</p>
                <p class="mt-1 whitespace-pre-wrap text-sm text-neutral-700"><%= clause_highlight_query.present? ? highlighted_summary_text(clause_summary, clause_highlight_query) : clause_summary %></p>

                <p class="mt-3 text-sm font-medium text-neutral-800">Content</p>
                <pre class="mt-1 whitespace-pre-wrap text-sm text-neutral-700"><%= clause_highlight_query.present? ? highlighted_summary_text(clause.content, clause_highlight_query) : clause.content %></pre>
              </li>
            <% end %>
          </ol>
        <% else %>
          <p class="mt-2 text-sm text-neutral-600">No clauses saved yet.</p>
        <% end %>
      </div>
    </section>
  <% end %>
</div>
