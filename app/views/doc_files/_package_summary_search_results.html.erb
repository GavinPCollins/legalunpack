<%# CODEX package-local header search %>
<% frame_id = local_assigns[:frame_id] || "summary_search_results" %>

<%= turbo_frame_tag frame_id do %>
  <% if query.present? %>
    <p class="search-drawer-query">Results for "<%= query %>"</p>
  <% end %>

  <% if package.present? %>
    <% ai_summary_matches = package.doc_files.filter_map do |doc_file|
         match_count = ai_summary_match_count(doc_file, query)
         [ doc_file, match_count ] if match_count.positive?
       end %>
    <% clause_matches = matching_clause_results(package, query) %>
    <% match_count = package_ai_summary_search_match_count(package, query) %>

    <p class="mt-4 text-sm font-semibold text-neutral-950">
      <%= pluralize(match_count, "match") %> in this package
    </p>

    <div class="mt-3 space-y-3">
      <% clause_matches.each do |clause| %>
        <div class="rounded-md border border-neutral-200 bg-neutral-50 p-3">
          <p class="text-xs font-semibold uppercase tracking-wide text-neutral-600">
            <% if clause.position.present? %>
              Clause <%= clause.position %> match
            <% else %>
              Clause match
            <% end %>
          </p>
          <div class="flex flex-wrap items-center gap-2">
            <p class="text-sm font-semibold text-neutral-950">
              <%= highlighted_search_text(clause.title.presence || "Untitled clause", query) %>
            </p>
            <% if clause.risk_level.present? %>
              <span class="rounded-full bg-white px-2 py-0.5 text-xs font-semibold text-neutral-600 ring-1 ring-neutral-200">
                <%= highlighted_search_text(clause.risk_level, query) %>
              </span>
            <% end %>
          </div>

          <% if clause.summary.present? %>
            <p class="mt-2 text-sm leading-6 text-neutral-700">
              <%= highlighted_search_text(clause.summary, query) %>
            </p>
          <% end %>

          <% if clause.content.present? %>
            <p class="mt-2 text-sm leading-6 text-neutral-600">
              <%= highlighted_search_text(clause.content, query) %>
            </p>
          <% end %>

          <% if clause.doc_file.present? %>
            <div class="mt-3">
              <%= link_to "Open clause",
                    summary_doc_file_path(clause.doc_file, highlight: query, anchor: dom_id(clause)),
                    class: "text-sm font-semibold text-cyan-800 hover:text-cyan-950",
                    data: { turbo_frame: "_top" } %>
            </div>
          <% end %>
        </div>
      <% end %>

      <% ai_summary_matches.each do |doc_file, count| %>
        <%= link_to summary_doc_file_path(doc_file, highlight: query, anchor: "file-summary"), class: "block rounded-md border border-cyan-100 bg-cyan-50/60 p-3 transition hover:border-cyan-200 hover:bg-cyan-50", data: { turbo_frame: "_top" } do %>
          <div class="flex items-start justify-between gap-3">
            <div class="min-w-0">
              <p class="text-xs font-semibold uppercase tracking-wide text-cyan-900">
                AI summary match
                <% if doc_file.file.attached? %>
                  <span class="normal-case tracking-normal text-cyan-700">- <%= doc_file.file.filename %></span>
                <% end %>
              </p>
              <p class="mt-1 text-sm text-neutral-700">Open AI summary</p>
            </div>
            <span class="shrink-0 rounded-full bg-white px-2.5 py-1 text-xs font-semibold text-cyan-900 ring-1 ring-cyan-100">
              <%= pluralize(count, "match") %>
            </span>
          </div>
        <% end %>
      <% end %>

    </div>
  <% elsif query.present? %>
    <div class="mt-4 rounded-md border border-dashed border-neutral-300 px-4 py-10 text-center">
      <p class="text-sm font-medium text-neutral-950">No matching package results</p>
      <p class="mt-1 text-sm text-neutral-500">Try another word or phrase from this package.</p>
    </div>
  <% else %>
    <p class="search-drawer-empty">Press Return to search this package.</p>
  <% end %>
<% end %>
